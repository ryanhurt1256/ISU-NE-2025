        dial_angles[1] = angle_from_detent(ch3_det)                                  # set CH3 dial angle directly from detent

        new_d2 = dial_detent(dial_angles[0])                                         # compute new CH2 detent after applying serial
        new_d3 = dial_detent(dial_angles[1])                                         # compute new CH3 detent after applying serial

        lever_moved = abs(lever_positions[0] - prev_lever_y) >= 2.0                  # ignore 1-px jitter from ADC noise
