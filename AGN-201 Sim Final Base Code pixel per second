        ch2_log_min = ch2_log_max - CH2_LOG_SPAN_DECADES                             # compute CH2 bottom decade

        pts2 = []                                                                    # create list of polyline points for CH2 trace
        for i, I in enumerate(ch2_list):                                             # iterate CH2 history values with index
