                    scram_start_time = now                                           # record SCRAM start time
                else:                                                                # if currently off
                    power_on = True                                                  # set power state to on
                    power_on_time = now                                              # record power-on timestamp
                    scram_active = False                                             # clear SCRAM state
                    scram_start_time = 0.0                                           # clear SCRAM timer
                    current_power = 1.0                                              # initialize displayed power to 1 W
                    power_raw_display = 1.0                                          # initialize uncapped power display to 1 W
                    n = max(1e-12, current_power / P_SCALE)                          # initialize neutron population from power
                    C = (beta / (Lambda * lam)) * n                                  # initialize precursor at steady-state for n
                    dial_angles[0] = angle_from_detent(2)                            # set CH2 dial to startup detent +2
                    dial_angles[1] = angle_from_detent(1)                            # set CH3 dial to startup detent +1
                    reset_instruments_to_power(current_power)                        # reset instrument histories and states
                    power_history.clear()                                            # clear power plot history
                    last_control_move_time = now                                     # inhibit scrams immediately after power-on
                continue                                                             # skip further selection logic after POWER click

            if scram_button_rect.collidepoint((mx, my)):                             # if SCRAM button clicked
