        # --- CH3 LIN (right) ---                                                    # section: draw CH3 linear trace
        det3 = dial_detent(dial_angles[1])                                           # read CH3 dial detent
        fs3 = CH3_RANGES[det3 + 3]                                                   # lookup CH3 full-scale from detent index

        pts3 = []                                                                    # create list of polyline points for CH3 trace
        for i, I in enumerate(ch3_list):                                             # iterate CH3 history values with index
            y = GRAPH_Y + (i / max(1, npts - 1)) * GRAPH_HEIGHT                      # map index to y position (top->bottom)
            frac = max(0.0, min(1.0, I / max(fs3, I_FLOOR)))                         # normalize current to [0,1] of full-scale
            x = right_start + frac * linear_width                                          # map fraction to x in right half
            pts3.append((x, y))                                                      # append plotted point
        pygame.draw.lines(screen, RED, False, smooth_points(pts3, steps=6), 2)       # draw smoothed CH3 polyline (red)

    pygame.draw.rect(screen, BLACK, (GRAPH_X, GRAPH_Y, linear_width, GRAPH_HEIGHT), 2)     # draw border around left plot half
    pygame.draw.rect(screen, BLACK, (right_start, GRAPH_Y, linear_width, GRAPH_HEIGHT), 2) # draw border around right plot half
    pygame.draw.line(screen, BLACK, (right_start, GRAPH_Y), (right_start, GRAPH_Y + GRAPH_HEIGHT), 2)  # draw center split line

    # -------------------------                                                      # section divider: text/readouts
    # TEXT / READOUTS                                                                # display numeric/status text
    # -------------------------                                                      # end section divider
    font = pygame.font.SysFont(None, 30)                                             # create main font for labels
    inst_font = pygame.font.SysFont(None, 20)                                        # create small font for instrument text
    title_font = pygame.font.SysFont(None, 26)                                       # create small font for plot titles

    # CH2 (LOG) info                                                                 # section: CH2 info line
    det2 = dial_detent(dial_angles[0])                                               # get CH2 detent for window
    ch2_log_max = CH2_LOG_MAX_AT_0 + det2                                            # compute CH2 top decade
    ch2_log_min = ch2_log_max - CH2_LOG_SPAN_DECADES                                 # compute CH2 bottom decade
    ch2_info = inst_font.render(                                                     # render CH2 status text surface
        f"CH2 (LOG): I={format_amps(ch2_I_ind)}  window=10^{int(ch2_log_min)}..10^{int(ch2_log_max)} A",  # formatted CH2 readout string
        True, BLACK                                                                  # antialias on, black text color
    )                                                                                # end render() call
    screen.blit(ch2_info, (GRAPH_X, GRAPH_Y - 86))                                   # draw CH2 info text above plot

    # CH3 (LIN + period) info                                                        # section: CH3 info lines
    det3 = dial_detent(dial_angles[1])                                               # get CH3 detent for full-scale
    fs3 = CH3_RANGES[det3 + 3]                                                       # compute CH3 full-scale from detent
    ch3_info = inst_font.render(                                                     # render CH3 status text surface
        f"CH3 (LIN): I={format_amps(ch3_I_ind)}  FS={format_amps(fs3)}",             # formatted CH3 readout string
        True, BLACK                                                                  # antialias on, black text color
    )                                                                                # end render() call
    screen.blit(ch3_info, (GRAPH_X, GRAPH_Y - 62))                                   # draw CH3 info above plot

    per_str = "—" if (not power_on) else ("∞" if ch3_period_s == float("inf") else f"{ch3_period_s:.1f}s")  # format period display string
    if scram_reason:                                                                 # only show if a SCRAM has occurred
        rtxt = inst_font.render(f"SCRAM Reason: {scram_reason}", True, BLACK)        # display latched SCRAM cause
        screen.blit(rtxt, (GRAPH_X, GRAPH_Y - 18))                                   # place below instrument readouts

    per_info = inst_font.render(f"CH3 Period: {per_str}   (scram @ {CH3_PERIOD_SCRAM_S:.0f}s)", True, BLACK) # render CH3 period line
    screen.blit(per_info, (GRAPH_X, GRAPH_Y - 38))                                   # draw period line above plot

    k_eff = 1.0 / max(1e-9, (1.0 - rho_new))                                         # compute implied k_eff from rho (guarded)
    dollars = rho_new / beta                                                         # compute reactivity in dollars ($) using beta

    p_text = font.render(f"Power (display): {power_raw_display:.2f} W", True, BLACK) # render power readout text
    screen.blit(p_text, p_text.get_rect(center=(GRAPH_X + GRAPH_WIDTH // 2, GRAPH_Y - 112)))  # center power text above plot

    k_text = inst_font.render(f"k_eff: {k_eff:.6f}   ρ: {rho_new:+.6f}   $: {dollars:+.2f}", True, BLACK)  # render k/rho/$ line
    screen.blit(k_text, k_text.get_rect(center=(GRAPH_X + GRAPH_WIDTH // 2, GRAPH_Y - 92)))    # center k/rho/$ above plot

    left_label = title_font.render("Channel 2 (Log Current)", True, BLACK)           # render left plot title text
    screen.blit(left_label, left_label.get_rect(center=(GRAPH_X + linear_width // 2, GRAPH_Y - 32))) # center left title above left half

    right_label = title_font.render("Channel 3 (Linear Current)", True, BLACK)       # render right plot title text
    screen.blit(right_label, right_label.get_rect(center=(right_start + linear_width // 2, GRAPH_Y - 32))) # center right title above right half

    y_label = font.render("Time (index)", True, BLACK)                               # render y-axis label
    y_label = pygame.transform.rotate(y_label, 90)                                   # rotate label 90° for vertical orientation
    screen.blit(y_label, y_label.get_rect(center=(GRAPH_X - 70, GRAPH_Y + GRAPH_HEIGHT // 2))) # draw y label left of plot

    draw_ticks_and_labels()                                                          # draw both x-axis and y-axis ticks/labels

    # -------------------------                                                      # section divider: buttons/controls
    # BUTTONS / CONTROLS                                                             # draw UI controls (power, scram, levers, dials)
    # -------------------------                                                      # end section divider
    pygame.draw.rect(screen, GREEN if power_on else GREY, power_button_rect)         # draw POWER button (green when on)
    btn_label = font.render("POWER", True, BLACK)                                    # render POWER button label
    screen.blit(btn_label, btn_label.get_rect(center=power_button_rect.center))      # draw POWER label centered on button

    pygame.draw.rect(screen, SCRAM_RED if scram_active else GREY, scram_button_rect) # draw SCRAM button (red when scrammed)
    scram_text = font.render("SCRAM", True, BLACK)                                   # render SCRAM label text
    screen.blit(scram_text, scram_text.get_rect(center=(scram_button_rect.centerx, scram_button_rect.bottom + 30))) # draw SCRAM label below button

    for i in range(NUM_LEVERS):                                                      # iterate levers to draw each track and handle
        x = lever_x_positions[i]                                                     # lever x center position
        y = lever_positions[i]                                                       # lever handle y position
        pygame.draw.rect(screen, GREY, (x - 6, LEVER_TRACK_TOP, 12, LEVER_TRACK_BOTTOM - LEVER_TRACK_TOP)) # draw lever track
        handle_color = (LEVER_INACTIVE_COLOR if (scram_active or not power_on) else (YELLOW if lever_active[i] else BLUE)) # choose handle color
        pygame.draw.rect(screen, handle_color, (x - 14, y, 28, LEVER_HEIGHT))        # draw lever handle rectangle
        name = font.render(lever_names[i], True, BLACK)                              # render lever name label
        screen.blit(name, name.get_rect(center=(x, LEVER_TRACK_BOTTOM + 34)))        # draw lever name below track

    scale_x = lever_x_positions[-1] + 95                                             # set x position for reactivity scale line
    scale_top = LEVER_TRACK_TOP                                                      # top y of scale line
    scale_bot = LEVER_TRACK_BOTTOM                                                   # bottom y of scale line
    pygame.draw.line(screen, BLACK, (scale_x, scale_top), (scale_x, scale_bot), 3)   # draw vertical reactivity scale line

    plus_lbl = font.render("+", True, BLACK)                                         # render plus sign label
    minus_lbl = font.render("-", True, BLACK)                                        # render minus sign label
    screen.blit(plus_lbl, plus_lbl.get_rect(center=(scale_x + 26, scale_top - 16)))  # draw plus sign near top of scale
    screen.blit(minus_lbl, minus_lbl.get_rect(center=(scale_x + 26, scale_bot + 16)))# draw minus sign near bottom of scale

    react_lbl = font.render("Reactivity", True, BLACK)                               # render "Reactivity" label
    screen.blit(react_lbl, react_lbl.get_rect(midleft=(scale_x + 48, (scale_top + scale_bot) // 2))) # draw label mid-scale

    rho_span = (0.60 * beta) - (-0.2)                                                # compute total rho span mapped to scale
    rho_frac = (rho_new - (-0.2)) / max(1e-9, rho_span)                              # normalize rho into [0,1] across span (guarded)
    rho_frac = max(0.0, min(1.0, rho_frac))                                          # clamp to [0,1]
    pointer_y = scale_bot - rho_frac * (scale_bot - scale_top)                       # map rho fraction to pointer y on scale
    pygame.draw.circle(screen, BLACK, (scale_x, int(pointer_y)), 6)                  # draw pointer dot on reactivity scale

    for i in range(NUM_DIALS):                                                       # iterate dials to draw each dial UI
        cx, cy = dial_centers[i]                                                     # dial center coordinates
        pygame.draw.circle(screen, GREY, (cx, cy), DIAL_RADIUS + 8)                  # draw dial outer ring
        face_color = (DIAL_INACTIVE_COLOR if not power_on else (YELLOW if dial_active[i] else DIAL_INACTIVE_COLOR)) # choose dial face color
        pygame.draw.circle(screen, face_color, (cx, cy), DIAL_RADIUS)                # draw dial face circle
        draw_dial_ticks(cx, cy, DIAL_RADIUS)                                         # draw tick marks and detent labels
        angle_rad = math.radians(dial_angles[i])                                     # convert dial angle to radians
        line_x = cx + DIAL_RADIUS * math.cos(angle_rad)                              # compute needle x endpoint
        line_y = cy + DIAL_RADIUS * math.sin(angle_rad)                              # compute needle y endpoint
        pygame.draw.line(screen, WHITE, (cx, cy), (line_x, line_y), 4)               # draw dial needle
        cap = font.render(dial_names[i], True, BLACK)                                # render dial caption text
        screen.blit(cap, cap.get_rect(center=(cx, cy - DIAL_RADIUS - 52)))           # draw dial caption above dial

    pygame.display.flip()                                                            # update the full display to the screen
    clock.tick(60)                                                                   # cap loop at 60 FPS

pygame.quit()                                                                        # uninitialize pygame and close window cleanly
sys.exit()                                                                           # exit program (clean termination)
