def clamp(v, lo, hi):                                                               # define a clamp helper
    return lo if v < lo else hi if v > hi else v                                    # return v clamped to [lo, hi]

def first_order_lag(y, x, dt, tau):                                                 # define a first-order lag filter
    if tau <= 1e-6:                                                                 # if tau is ~0, treat as no filtering
        return x                                                                    # return the input immediately
    alpha = dt / (tau + dt)                                                         # compute discrete-time filter weight
    return y + alpha * (x - y)                                                      # return filtered output

def format_amps(I):                                                                 # define helper to format currents nicely
    I = float(I)                                                                    # ensure numeric float
    a = abs(I)                                                                      # compute absolute magnitude
    if a >= 1e-6:                                                                   # if microamp range
        return f"{I/1e-6:.2f} µA"                                                   # format as µA
    if a >= 1e-9:                                                                   # if nanoamp range
        return f"{I/1e-9:.2f} nA"                                                   # format as nA
    if a >= 1e-12:                                                                  # if picoamp range
        return f"{I/1e-12:.2f} pA"                                                  # format as pA
    return f"{I:.2e} A"                                                             # otherwise format in scientific notation

def format_watts(P):                                                                # define helper to format power nicely
    P = float(P)                                                                    # ensure numeric float
    if P >= 1.0:                                                                    # if >= 1 W
        return f"{P:.2f} W"                                                         # show 2 decimals
    if P >= 0.01:                                                                   # if 0.01..1 W
        return f"{P:.4f} W"                                                         # show 4 decimals
    return f"{P:.6f} W"                                                             # otherwise show 6 decimals

# -------------------- ROD WORTH CURVE --------------------                         # section header: rod worth shape model
# Normalized so rod_curve(1.0) == 1.0 exactly.                                      # documentation comment
def rod_curve(withdrawn_frac):                                                      # define rod worth curve function
    a = 3.3                                                                         # curvature parameter (tunes "S" shape)
    x = clamp(float(withdrawn_frac), 0.0, 1.0)                                      # clamp input fraction to [0, 1]
    denom = 1.0 - math.exp(-a)                                                      # normalization denominator
    return (1.0 - math.exp(-a * x)) / max(1e-12, denom)                             # return normalized exponential curve

