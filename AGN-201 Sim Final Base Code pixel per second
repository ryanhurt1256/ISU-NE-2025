    screen.fill(WHITE)                                                              # clear background each frame
    now = time.time()                                                               # current wall-clock time
    dt = now - last_time                                                            # compute delta-time since last frame
    if dt <= 0.0:                                                                   # guard against non-positive dt
        dt = 1.0 / 60.0                                                             # substitute nominal frame time
    if dt > 0.1:                                                                    # clamp dt to prevent physics blow-up on stalls
        dt = 0.1                                                                    # cap dt at 0.1 s
    last_time = now                                                                 # store for next iteration

    # -------- Serial controls --------                                              # section header: serial input handling
    serial_controls = read_controls_from_serial(ser)                                # attempt to read one serial packet
    if serial_controls is not None:                                                 # if valid packet received
        last_serial_rx_time = now                                                   # update last receive timestamp
        last_serial_controls = serial_controls                                      # store packet as latest control state

    serial_live = (now - last_serial_rx_time) <= SERIAL_TIMEOUT_S                   # determine if serial is considered "alive"
    if not serial_live:                                                            # if serial has timed out
        last_serial_controls = None                                                 # clear controls so UI doesn't keep stale input
        #prev_power_sw = False                                                       # reset edge detector to avoid false rise. commented out for glitch in false OFF --> ON edge

    if last_serial_controls is not None and serial_live:                            # if we have fresh serial controls
        fine_frac, ch2_det, ch3_det, power_sw, scram_sw = last_serial_controls      # unpack parsed control values

        # Power-cycle clears Python-side SCRAM inhibit                              # comment: scram acknowledge rule
        if not power_sw:                                                            # if power switch is OFF
            scram_inhibit_until_power_cycle = False                                 # clear inhibit so scram_sw can be recognized next time

        prev_lever_y = lever_positions[0]                                           # store previous lever y for movement detection
        prev_d2 = dial_detents[0]                                                   # store previous CH2 detent
        prev_d3 = dial_detents[1]                                                   # store previous CH3 detent

        travel = (LEVER_TRACK_BOTTOM - LEVER_TRACK_TOP - LEVER_HEIGHT)              # compute usable lever travel distance
        frac = clamp(float(fine_frac), 0.0, 1.0)                                    # clamp incoming rod fraction

        # ---- Arduino rod_frac 0=inserted(bottom), 1=withdrawn(top) ----           # comment: rod mapping convention
        target_y = (LEVER_TRACK_BOTTOM - LEVER_HEIGHT) - frac * travel              # map fraction to lever y (0->down, 1->up)

        max_step = ROD_SPEED_PX_S * dt                                              # compute maximum lever follow step this frame
        dy = target_y - lever_positions[0]                                          # compute desired delta
        if abs(dy) <= max_step:                                                     # if we can reach target in one step
            lever_positions[0] = target_y                                           # snap to target
        else:                                                                       # otherwise limit motion rate
            lever_positions[0] += max_step * (1.0 if dy > 0 else -1.0)              # move toward target by max_step

        lever_positions[0] = clamp(lever_positions[0], LEVER_TRACK_TOP, LEVER_TRACK_BOTTOM - LEVER_HEIGHT)  # clamp lever within track

        dial_detents[0] = clamp(int(ch2_det), -3, 3)                                # update CH2 detent from serial input
        dial_detents[1] = clamp(int(ch3_det), -3, 3)                                # update CH3 detent from serial input

        lever_moved = abs(lever_positions[0] - prev_lever_y) >= 2.0                 # detect lever movement above a threshold
        dial_changed = (dial_detents[0] != prev_d2) or (dial_detents[1] != prev_d3) # detect dial detent changes
        if lever_moved or dial_changed:                                             # if any control moved
            last_control_move_time = now                                            # update movement timestamp (trip inhibit logic)

        power_rise = (power_sw and not prev_power_sw)                               # rising edge detect: OFF->ON
        power_fall = ((not power_sw) and prev_power_sw)                             # falling edge detect: ON->OFF
        prev_power_sw = power_sw                                                    # store current power switch state

        if power_rise and (not power_on):                                           # if power just turned ON
            power_on = True                                                         # enable simulation
            power_on_time = now                                                     # store power-on timestamp for grace period
            scram_active = False                                                    # clear SCRAM state
            scram_start_time = 0.0                                                  # clear scram start time
            scram_reason = ""                                                       # clear scram reason string
            dial_detents[0] = 0                                                     # reset CH2 dial to 0 detent (startup default)
            dial_detents[1] = 0                                                     # reset CH3 dial to 0 detent (startup default)
            n = max(1e-12, 1.0 / P_SCALE)                                           # initialize n so power starts near 1 W
            C = (beta / (Lambda * lam)) * n                                         # initialize C near steady-state for given n
            reset_instruments_to_power(1.0)                                         # initialize instrument indications near 1 W
            power_history.clear()                                                   # clear power history buffer
            last_control_move_time = now                                            # treat startup as a "move" for inhibit timing

        if power_fall and power_on and not scram_active:                            # if power turned OFF while on and not already scrammed
            scram_active = True                                                     # enter SCRAM state
            scram_start_time = now                                                  # record scram start
            scram_reason = "POWER SWITCH OFF"                                       # set scram reason text
            scram_reason_time = now                                                 # record reason timestamp
            scram_inhibit_until_power_cycle = True                                  # inhibit external scram until power cycles

        # ---- Python-side SCRAM latch behavior: ignore scram_sw until power cycles ---- # comment: external scram inhibit
        if (not scram_inhibit_until_power_cycle) and scram_sw and (not scram_active): # if scram_sw asserted and not inhibited
            scram_active = True                                                     # enter SCRAM state
            scram_start_time = now                                                  # record scram start
            scram_reason = "EXTERNAL SCRAM"                                         # set scram reason text
            scram_reason_time = now                                                 # record reason timestamp
            scram_inhibit_until_power_cycle = True                                  # inhibit further scram until power cycles

    # -------- Events --------                                                       # section header: pygame event processing
    for event in pygame.event.get():                                                # process all pending events
        if event.type == pygame.QUIT:                                               # if window close requested
            running = False                                                         # terminate loop

        elif event.type == pygame.MOUSEBUTTONDOWN:                                  # if mouse button pressed
            mx, my = event.pos                                                      # read mouse coordinates

            if power_button_rect.collidepoint((mx, my)):                            # if click on POWER button
                if power_on:                                                        # if already powered on
                    scram_active = True                                             # treat as power-off scram
                    scram_start_time = now                                          # record scram start time
                    scram_reason = "POWER BUTTON OFF"                               # set scram reason
                    scram_reason_time = now                                         # record reason time
                    scram_inhibit_until_power_cycle = True                          # inhibit further scram until power cycles
                else:                                                               # if currently off and turning on
                    power_on = True                                                 # enable simulation
                    power_on_time = now                                             # store power-on timestamp
                    scram_active = False                                            # clear scram state
                    scram_start_time = 0.0                                          # clear scram start
                    scram_reason = ""                                               # clear scram reason
                    dial_detents[0] = 0                                             # reset CH2 dial to detent 0
                    dial_detents[1] = 0                                             # reset CH3 dial to detent 0
                    n = max(1e-12, 1.0 / P_SCALE)                                   # initialize n for ~1 W start
                    C = (beta / (Lambda * lam)) * n                                 # initialize C near steady-state
                    reset_instruments_to_power(1.0)                                 # initialize instruments
                    power_history.clear()                                           # clear power history
                    last_control_move_time = now                                    # update movement time (inhibit trips)
                continue                                                            # skip further processing for this click

            if scram_button_rect.collidepoint((mx, my)):                            # if click on SCRAM button
                if power_on and (not scram_active):                                 # if powered and not already scrammed
                    scram_active = True                                             # enter SCRAM state
                    scram_start_time = now                                          # record scram start
                    scram_reason = "MANUAL SCRAM"                                   # set scram reason
                    scram_reason_time = now                                         # record reason time
                    scram_inhibit_until_power_cycle = True                          # inhibit external scram until power cycles
                continue                                                            # skip further processing for this click

            if power_on and not scram_active:                                       # only allow selecting controls when powered and not scrammed
                lever_clicked = False                                               # initialize lever click flag
                for i, x in enumerate(lever_x_positions):                           # iterate levers with their x positions
                    if (x - 14 < mx < x + 14 and lever_positions[i] < my < lever_positions[i] + LEVER_HEIGHT):  # if click inside lever handle
                        lever_clicked = True                                        # mark lever clicked
                        lever_active[:] = [False] * NUM_LEVERS                      # clear all lever highlights
                        dial_active[:]  = [False] * NUM_DIALS                       # clear all dial highlights
                        selected_dial = None                                        # clear dial selection
                        selected_lever = i                                          # select this lever
                        lever_active[i] = True                                      # highlight this lever
                        lever_activation_time[i] = now                              # record activation time
                        break                                                       # stop searching levers

                if not lever_clicked:                                               # if no lever was clicked
                    for i, (cx, cy) in enumerate(dial_centers):                     # iterate dials with their centers
                        if math.hypot(mx - cx, my - cy) < DIAL_RADIUS + 12:         # if click within dial hit radius
                            lever_active[:] = [False] * NUM_LEVERS                  # clear lever highlights
                            dial_active[:]  = [False] * NUM_DIALS                   # clear dial highlights
                            selected_lever = None                                   # clear lever selection
                            selected_dial = i                                       # select this dial
                            dial_active[i] = True                                   # highlight this dial
                            dial_activation_time[i] = now                           # record activation time
                            break                                                   # stop searching dials

    # -------- Keyboard control --------                                            # section header: keyboard control logic
    keys = pygame.key.get_pressed()                                                 # read current keyboard state
    moved_this_frame = False                                                        # track if any control moved (for inhibit timing)

    if power_on and not scram_active:                                               # only allow manual movement when powered and not scrammed
        shift_held = keys[pygame.K_LSHIFT] or keys[pygame.K_RSHIFT]                 # detect SHIFT key for fast movement
        lever_mult = LEVER_FAST_MULT if shift_held else 1.0                         # choose lever speed multiplier

        # lever                                                                     # section: keyboard lever motion
        if selected_lever is not None and lever_active[selected_lever]:             # if a lever is selected and active
            if keys[pygame.K_UP]:                                                   # if UP arrow held
                lever_positions[selected_lever] -= LEVER_SPEED_PX_S * dt * lever_mult  # move lever up
                lever_activation_time[selected_lever] = now                         # refresh activation time
                moved_this_frame = True                                             # record movement
            elif keys[pygame.K_DOWN]:                                               # if DOWN arrow held
                lever_positions[selected_lever] += LEVER_SPEED_PX_S * dt * lever_mult  # move lever down
                lever_activation_time[selected_lever] = now                         # refresh activation time
                moved_this_frame = True                                             # record movement

            lever_positions[selected_lever] = clamp(                                # clamp lever within track limits
                lever_positions[selected_lever],                                    # current lever y
                LEVER_TRACK_TOP,                                                    # top limit
                LEVER_TRACK_BOTTOM - LEVER_HEIGHT                                   # bottom limit
            )

        # dials (detented)                                                              # section: keyboard dial stepping
        if selected_dial is not None and dial_active[selected_dial]:                # if a dial is selected and active
            dial_activation_time[selected_dial] = now                               # refresh activation time
            can_step = (now - last_dial_step_time) >= DIAL_STEP_REPEAT_DELAY_S      # enforce step repeat delay
            if can_step:                                                            # if enough time elapsed
                if keys[pygame.K_LEFT]:                                             # if LEFT arrow held
                    dial_detents[selected_dial] = clamp(dial_detents[selected_dial] - 1, -3, 3)  # step down one detent
                    last_dial_step_time = now                                       # record step time
                    moved_this_frame = True                                         # record movement
                elif keys[pygame.K_RIGHT]:                                          # if RIGHT arrow held
                    dial_detents[selected_dial] = clamp(dial_detents[selected_dial] + 1, -3, 3)  # step up one detent
                    last_dial_step_time = now                                       # record step time
                    moved_this_frame = True                                         # record movement

    if moved_this_frame:                                                            # if any movement occurred this frame
        last_control_move_time = now                                                # update movement timestamp for inhibit logic

    # cooldown deselect                                                               # section header: auto-deselect after inactivity
    for i in range(NUM_LEVERS):                                                     # iterate levers
        if lever_active[i] and (now - lever_activation_time[i]) > COOLDOWN_TIME:    # if lever active but cooldown expired
            lever_active[i] = False                                                 # deactivate lever highlight
            if selected_lever == i:                                                 # if this lever was selected
                selected_lever = None                                               # clear selection

    for i in range(NUM_DIALS):                                                      # iterate dials
        if dial_active[i] and (now - dial_activation_time[i]) > COOLDOWN_TIME:      # if dial active but cooldown expired
            dial_active[i] = False                                                  # deactivate dial highlight
            if selected_dial == i:                                                  # if this dial was selected
                selected_dial = None                                                # clear selection

    # SCRAM forces rod in (screen lever down)                                       # section header: scram visual override
    if scram_active:                                                                # if SCRAM is active
        lever_positions[:] = [LEVER_TRACK_BOTTOM - LEVER_HEIGHT] * NUM_LEVERS       # force lever to inserted/down position

    # auto reset after delay                                                        # section header: scram reset behavior
    if scram_active and (now - scram_start_time > 3.0):                             # if scram has been active long enough
        power_on = False                                                            # drop power off after scram delay
        scram_active = False                                                        # clear scram active flag
        scram_start_time = 0.0                                                      # reset scram start time
        power_raw_display = 0.0                                                     # reset displayed raw power
        current_power_display = 0.0                                                 # reset clamped displayed power
        n = 1e-12                                                                   # reset neutron population
        C = 0.0                                                                     # reset precursors
        rho_prev = 0.0                                                              # reset previous reactivity
        rho_new  = 0.0                                                              # reset current reactivity
        power_history.clear()                                                       # clear power history buffer
        ch2_history.clear()                                                         # clear CH2 history buffer
        ch3_history.clear()                                                         # clear CH3 history buffer
        ch3_ln_buf.clear()                                                          # clear period fit buffer
        ch3_period_s = float("inf")                                                 # reset period estimate
        ch3_period_bad_time = 0.0                                                   # reset bad period time accumulator
        ch2_hi_lockout = False                                                      # clear CH2 lockout latch
        lever_positions[:] = [LEVER_TRACK_BOTTOM - LEVER_HEIGHT] * NUM_LEVERS       # reset lever position to inserted/down
        dial_detents[0] = 0                                                         # reset CH2 detent to zero
        dial_detents[1] = 0                                                         # reset CH3 detent to zero
        selected_lever = None                                                       # clear lever selection
        selected_dial  = None                                                       # clear dial selection
        lever_active[:] = [False] * NUM_LEVERS                                      # clear lever active flags
        dial_active[:]  = [False] * NUM_DIALS                                       # clear dial active flags
        last_control_move_time = now                                                # update movement timestamp
        last_dial_step_time = 0.0                                                   # reset dial step timer
        # NOTE: scram_inhibit_until_power_cycle remains True until power is OFF     # document inhibit behavior

    # -------- PHYSICS --------                                                     # section header: kinetics + trip logic
    if power_on and not scram_active:                                               # only evolve physics when powered and not scrammed
        travel = (LEVER_TRACK_BOTTOM - LEVER_TRACK_TOP - LEVER_HEIGHT)              # compute lever travel distance

        # withdrawn fraction: 0 inserted (down), 1 withdrawn (up)                    # comment: lever -> withdrawn fraction
        x_withdrawn = (LEVER_TRACK_BOTTOM - LEVER_HEIGHT - lever_positions[0]) / travel if travel > 0.0 else 0.0  # compute withdrawn fraction
        x_withdrawn = clamp(x_withdrawn, 0.0, 1.0)                                   # clamp withdrawn fraction to [0, 1]

        worth_fraction = rod_curve(x_withdrawn)                                      # convert withdrawn fraction to worth fraction

        rho_cmd = RHO_BASE + RHO_WORTH * worth_fraction                              # compute commanded reactivity from rod worth
        rho_cmd = clamp(rho_cmd, RHO_NEG_LIMIT, RHO_POS_LIMIT)                       # clamp rho to safe bounds

        if abs(rho_cmd - rho_prev) < RHO_DEADBAND:                                   # apply deadband to reduce chatter
            rho_cmd = rho_prev                                                       # hold previous value within deadband
        rho_new = first_order_lag(rho_prev, rho_cmd, dt, RHO_TAU)                    # filter reactivity with first-order lag

        substeps = 12                                                                # number of integration substeps per frame
        dt_sub = dt / max(1, substeps)                                               # compute substep time increment
        for _ in range(substeps):                                                    # integrate across substeps
            n, C = rk4_step((n, C), dt_sub, rho_new)                                 # advance n and C by one RK4 step
            if (not (n == n)) or n < 1e-12:                                          # guard against NaN or too-small n
                n = 1e-12                                                            # enforce minimum n
            if (not (C == C)) or C < 0.0:                                            # guard against NaN or negative C
                C = 0.0                                                              # enforce non-negative precursors

        power_raw = max(0.0, P_SCALE * n)                                            # compute raw power from n (watts)
        power_raw_display = power_raw                                                # store raw power for text display
        current_power_display = clamp(power_raw, 0.0, MAX_POWER_DISPLAY)             # clamp power for plotting
        power_history.append(current_power_display)                                  # append power sample to history

        # instrument currents                                                         # section: instrument simulation
        ch2_I_true = max(I_FLOOR, I_PER_WATT_CH2 * power_raw)                         # compute ideal CH2 current from power
        ch3_I_true = max(I_FLOOR, I_PER_WATT_CH3 * power_raw)                         # compute ideal CH3 current from power
        ch2_I_ind = first_order_lag(ch2_I_ind, ch2_I_true, dt, CH2_TAU)               # filter CH2 current (instrument lag)
        ch3_I_ind = first_order_lag(ch3_I_ind, ch3_I_true, dt, CH3_TAU)               # filter CH3 current (instrument lag)

        # period from CH3 indication                                                   # section: period estimation
        lnI3 = math.log(max(ch3_I_ind, I_FLOOR))                                      # compute ln(I) safely
        ch3_ln_buf.append((now, lnI3))                                                # add sample to buffer
        while ch3_ln_buf and (now - ch3_ln_buf[0][0]) > CH3_PERIOD_FIT_WINDOW_S:      # drop samples older than fit window
            ch3_ln_buf.popleft()                                                      # remove oldest sample
        ch3_period_s = fit_period_from_buffer(ch3_ln_buf)                             # compute fitted period estimate

        ch2_history.append(ch2_I_ind)                                                 # append CH2 indicated current to history
        ch3_history.append(ch3_I_ind)                                                 # append CH3 indicated current to history

        grace = (now - power_on_time) < SCRAM_GRACE_S                                  # determine if still in startup grace window
        moving_inhibit = (now - last_control_move_time) < CONTROL_MOVE_INHIBIT_S      # determine if within movement inhibit window

        scram_trip = False                                                            # initialize trip flag
        trip_reason = ""                                                              # initialize trip reason string

        # CH3 range-scaled low/high                                                    # section: CH3 window trips
        det3 = dial_detents[1]                                                        # get CH3 detent
        fs3 = CH3_RANGES[det3 + 3]                                                    # compute full-scale current for detent
        ch3_low_trip  = CH3_LOW_PCT_FS  * fs3                                         # compute low trip threshold
        ch3_high_trip = CH3_HIGH_PCT_FS * fs3                                         # compute high trip threshold

        if (not grace) and (ch3_I_ind <= ch3_low_trip):                               # if below low threshold outside grace
            scram_trip = True                                                         # set trip
            trip_reason = "CH3 LOW (LIN) <= 1%FS"                                     # set reason
        if (not grace) and (ch3_I_ind >= ch3_high_trip):                              # if above high threshold outside grace
            scram_trip = True                                                         # set trip
            trip_reason = "CH3 HIGH (LIN) >= 95%FS"                                   # set reason

        # absolute high-power backstop (~10 W)                                        # section: absolute high trip
        if (not grace) and (ch3_I_ind >= CH3_HIGH_SCRAM_A):                           # if above absolute limit outside grace
            scram_trip = True                                                         # set trip
            trip_reason = "CH3 HIGH (ABS) (HIGH POWER)"                               # set reason

        # period scram (only when signal is healthy)                                  # section: period trip logic
        period_ok_signal = (ch3_I_ind > max(20.0 * I_FLOOR, 0.05 * fs3))              # require signal above noise floor and some FS fraction
        if (not grace) and (not moving_inhibit) and period_ok_signal and (ch3_period_s != float("inf")):  # if allowed to evaluate period
            if ch3_period_s <= CH3_PERIOD_SCRAM_S:                                    # if period too short
                ch3_period_bad_time += dt                                             # accumulate bad time
            else:                                                                     # if period acceptable
                ch3_period_bad_time = max(0.0, ch3_period_bad_time - 2.0 * dt)        # bleed down bad time accumulator
        else:                                                                         # if grace/inhibit/no-signal
            ch3_period_bad_time = 0.0                                                 # reset bad time accumulator

        if (not grace) and (not moving_inhibit) and (ch3_period_bad_time >= CH3_PERIOD_PERSIST_S):  # if persisted bad period
            scram_trip = True                                                         # set trip
            trip_reason = "CH3 PERIOD (LIN) persist"                                  # set reason

        # CH2 LOG window + lockout                                                    # section: CH2 window/lockout logic
        det2 = dial_detents[0]                                                        # get CH2 detent
        ch2_log_max = CH2_LOG_MAX_AT_0 + det2                                         # compute log10 max for window
        ch2_log_min = ch2_log_max - CH2_LOG_SPAN_DECADES                              # compute log10 min for window
        logI2 = math.log10(max(ch2_I_ind, I_FLOOR))                                   # compute log10 current safely
        frac2 = (logI2 - ch2_log_min) / max(1e-9, (ch2_log_max - ch2_log_min))        # map log current to [0, 1]
        frac2 = clamp(frac2, 0.0, 1.0)                                                # clamp fraction

        if (not grace) and (ch2_I_ind > CH2_MAX_LOCKOUT_A):                           # if CH2 exceeds absolute lockout
            ch2_hi_lockout = True                                                     # latch lockout
            scram_trip = True                                                         # trip
            trip_reason = "CH2 LOCKOUT (LOG) I > lockout"                             # set reason
        if (not grace) and (not moving_inhibit) and ((frac2 <= CH2_LOW_PCT_SCRAM) or (frac2 >= CH2_HI_PCT_SCRAM)):  # if out of window
            scram_trip = True                                                         # trip
            trip_reason = "CH2 WINDOW (LOG) outside pct limits"                       # set reason

        if scram_trip:                                                                # if any scram condition triggered
            scram_active = True                                                       # enter SCRAM state
            scram_start_time = now                                                    # record scram start
            scram_reason = trip_reason if trip_reason else "UNKNOWN SCRAM"            # store reason text
            scram_reason_time = now                                                   # record reason time
            scram_inhibit_until_power_cycle = True                                    # inhibit external scram until power cycles
            selected_lever = None                                                     # clear lever selection
            selected_dial  = None                                                     # clear dial selection
            lever_active[:] = [False] * NUM_LEVERS                                    # clear lever active flags
            dial_active[:]  = [False] * NUM_DIALS                                     # clear dial active flags

        rho_prev = rho_new                                                            # update previous rho for next iteration

    else:                                                                             # if not powered or scrammed
        ch2_I_ind = first_order_lag(ch2_I_ind, I_FLOOR, dt, 0.5)                      # decay CH2 indicated current toward floor
        ch3_I_ind = first_order_lag(ch3_I_ind, I_FLOOR, dt, 0.5)                      # decay CH3 indicated current toward floor
        ch3_period_s = float("inf")                                                   # reset period estimate
        ch3_ln_buf.clear()                                                            # clear period buffer
        ch3_period_bad_time = 0.0                                                     # reset period bad time

    # -------- PLOTS --------                                                         # section header: draw plots
    pygame.draw.rect(screen, GREY, (GRAPH_X, GRAPH_Y, GRAPH_WIDTH, GRAPH_HEIGHT))    # draw plot background rectangle
    linear_width = GRAPH_WIDTH // 2                                                  # compute half-width for left and right plot panes
    right_start = GRAPH_X + linear_width                                             # compute x offset for right plot pane

    if len(ch2_history) > 1 and len(ch3_history) > 1:                                # only draw lines when we have enough samples
        npts = min(len(ch2_history), len(ch3_history))                               # choose common sample count
        ch2_list = list(ch2_history)[-npts:]                                         # convert CH2 history to list and align end
        ch3_list = list(ch3_history)[-npts:]                                         # convert CH3 history to list and align end

        # CH2 LOG                                                                     # section: draw CH2 log trace
        det2 = dial_detents[0]                                                        # current CH2 detent
        ch2_log_max = CH2_LOG_MAX_AT_0 + det2                                         # compute log10 max for display window
        ch2_log_min = ch2_log_max - CH2_LOG_SPAN_DECADES                              # compute log10 min for display window
        pts2 = []                                                                     # initialize polyline point list
        for i, I in enumerate(ch2_list):                                              # iterate over samples
            y = GRAPH_Y + (i / max(1, npts - 1)) * GRAPH_HEIGHT                       # map index to vertical position
            logI = math.log10(max(I, I_FLOOR))                                        # compute log current safely
            frac = (logI - ch2_log_min) / max(1e-9, (ch2_log_max - ch2_log_min))      # map to [0, 1] across window
            frac = clamp(frac, 0.0, 1.0)                                              # clamp to visible range
            x = GRAPH_X + frac * linear_width                                         # map to x coordinate
            pts2.append((x, y))                                                       # append point
        pygame.draw.lines(screen, YELLOW, False, pts2, 2)                             # draw CH2 polyline

        # CH3 LIN                                                                     # section: draw CH3 linear trace
        det3 = dial_detents[1]                                                        # current CH3 detent
        fs3 = CH3_RANGES[det3 + 3]                                                    # full-scale current for CH3 detent
        pts3 = []                                                                     # initialize polyline point list
        for i, I in enumerate(ch3_list):                                              # iterate over samples
            y = GRAPH_Y + (i / max(1, npts - 1)) * GRAPH_HEIGHT                       # map index to vertical position
            frac = clamp(I / max(fs3, I_FLOOR), 0.0, 1.0)                             # normalize to full-scale and clamp
            x = right_start + frac * linear_width                                     # map to x coordinate on right pane
            pts3.append((x, y))                                                       # append point
        pygame.draw.lines(screen, RED, False, smooth_points(pts3, steps=6), 2)        # draw smoothed CH3 polyline

    pygame.draw.rect(screen, BLACK, (GRAPH_X, GRAPH_Y, linear_width, GRAPH_HEIGHT), 2)  # outline left plot pane
    pygame.draw.rect(screen, BLACK, (right_start, GRAPH_Y, linear_width, GRAPH_HEIGHT), 2)  # outline right plot pane
    pygame.draw.line(screen, BLACK, (right_start, GRAPH_Y), (right_start, GRAPH_Y + GRAPH_HEIGHT), 2)  # divider line

    # -------- TEXT --------                                                          # section header: draw text overlays
    font = pygame.font.SysFont(None, 30)                                              # main text font
    inst_font = pygame.font.SysFont(None, 20)                                         # instrument detail font
    title_font = pygame.font.SysFont(None, 26)                                        # plot title font
    small_font = pygame.font.SysFont(None, 18)                                        # small debug/labels font

    det2 = dial_detents[0]                                                            # current CH2 detent
    ch2_log_max = CH2_LOG_MAX_AT_0 + det2                                             # compute CH2 log max exponent
    ch2_log_min = ch2_log_max - CH2_LOG_SPAN_DECADES                                  # compute CH2 log min exponent
    ch2_info = inst_font.render(                                                      # render CH2 info line
        f"CH2 (LOG): I={format_amps(ch2_I_ind)}  window=10^{int(ch2_log_min)}..10^{int(ch2_log_max)} A",  # formatted info text
        True, BLACK                                                                   # antialias + color
    )
    screen.blit(ch2_info, (GRAPH_X, GRAPH_Y - 86))                                    # draw CH2 info above plot

    det3 = dial_detents[1]                                                           # current CH3 detent
    fs3 = CH3_RANGES[det3 + 3]                                                       # CH3 full-scale for detent
    ch3_info = inst_font.render(                                                     # render CH3 info line
        f"CH3 (LIN): I={format_amps(ch3_I_ind)}  FS={format_amps(fs3)}",             # formatted info text
        True, BLACK                                                                  # antialias + color
    )
    screen.blit(ch3_info, (GRAPH_X, GRAPH_Y - 62))                                   # draw CH3 info above plot

    per_str = "—" if (not power_on) else ("∞" if ch3_period_s == float("inf") else f"{ch3_period_s:.1f}s")  # choose period display string
    per_info = inst_font.render(f"CH3 Period: {per_str}   (scram @ {CH3_PERIOD_SCRAM_S:.0f}s)", True, BLACK) # render period info line
    screen.blit(per_info, (GRAPH_X, GRAPH_Y - 38))                                   # draw period info above plot

    if scram_reason:                                                                 # if scram reason is non-empty
        rtxt = inst_font.render(f"SCRAM Reason: {scram_reason}", True, BLACK)        # render scram reason line
        screen.blit(rtxt, (GRAPH_X, GRAPH_Y - 18))                                   # draw scram reason above plot

    k_eff = 1.0 / max(1e-9, (1.0 - rho_new))                                         # approximate k_eff from rho (rho=(k-1)/k)
    dollars = rho_new / beta                                                         # compute reactivity in dollars ($ = rho/beta)

    p_text = font.render(f"Power (raw): {format_watts(power_raw_display)}", True, BLACK)  # render power readout
    screen.blit(p_text, p_text.get_rect(center=(GRAPH_X + GRAPH_WIDTH // 2, GRAPH_Y - 112)))  # center power above plot

    k_text = inst_font.render(f"k_eff: {k_eff:.6f}   ρ: {rho_new:+.6f}   $: {dollars:+.2f}", True, BLACK)  # render kinetics info line
    screen.blit(k_text, k_text.get_rect(center=(GRAPH_X + GRAPH_WIDTH // 2, GRAPH_Y - 92)))                 # center kinetics line

    # titles shifted up + right                                                       # comment: requested title shift
    left_label = title_font.render("Channel 2 (Log Current)", True, BLACK)           # render left plot title
    screen.blit(left_label, left_label.get_rect(center=(GRAPH_X + linear_width // 2 + 20, GRAPH_Y - 54)))  # draw left title shifted

    right_label = title_font.render("Channel 3 (Linear Current)", True, BLACK)       # render right plot title
    screen.blit(right_label, right_label.get_rect(center=(right_start + linear_width // 2 + 20, GRAPH_Y - 54)))  # draw right title shifted

    y_label = font.render("Time (index)", True, BLACK)                               # render y-axis label
    y_label = pygame.transform.rotate(y_label, 90)                                   # rotate label vertically
    screen.blit(y_label, y_label.get_rect(center=(GRAPH_X - 70, GRAPH_Y + GRAPH_HEIGHT // 2)))  # draw y-label to left

    draw_ticks_and_labels()                                                          # draw axis ticks/labels for both panes

    # -------- BUTTONS --------                                                        # section header: draw buttons
    pygame.draw.rect(screen, GREEN if power_on else GREY, power_button_rect)         # draw power button rectangle (green when on)
    btn_label = font.render("POWER", True, BLACK)                                    # render power button text
    screen.blit(btn_label, btn_label.get_rect(center=power_button_rect.center))     # center text on power button

    pygame.draw.rect(screen, SCRAM_RED if scram_active else GREY, scram_button_rect) # draw scram button rectangle (red when active)
    scram_text = font.render("SCRAM", True, BLACK)                                   # render scram label
    screen.blit(scram_text, scram_text.get_rect(center=(scram_button_rect.centerx, scram_button_rect.bottom + 30)))  # place label under button

    # -------- LEVER --------                                                          # section header: draw lever(s)
    for i in range(NUM_LEVERS):                                                      # iterate levers
        x = lever_x_positions[i]                                                     # lever center x
        y = lever_positions[i]                                                       # lever top y
        pygame.draw.rect(screen, GREY, (x - 6, LEVER_TRACK_TOP, 12, LEVER_TRACK_BOTTOM - LEVER_TRACK_TOP))  # draw lever track
        handle_color = LEVER_INACTIVE_COLOR if (scram_active or not power_on) else (YELLOW if lever_active[i] else BLUE)  # choose handle color
        pygame.draw.rect(screen, handle_color, (x - 14, y, 28, LEVER_HEIGHT))        # draw lever handle rectangle
        name = font.render(lever_names[i], True, BLACK)                              # render lever name
        screen.blit(name, name.get_rect(center=(x, LEVER_TRACK_BOTTOM + 34)))        # draw lever name under track

    # Reactivity scale                                                                # section header: draw reactivity scale
    scale_x = lever_x_positions[-1] + 95                                             # x position of reactivity scale
    scale_top = LEVER_TRACK_TOP                                                      # y position of scale top
    scale_bot = LEVER_TRACK_BOTTOM                                                   # y position of scale bottom
    pygame.draw.line(screen, BLACK, (scale_x, scale_top), (scale_x, scale_bot), 3)   # draw vertical scale line

    plus_lbl = font.render("+", True, BLACK)                                         # render plus sign
    minus_lbl = font.render("-", True, BLACK)                                        # render minus sign
    screen.blit(plus_lbl, plus_lbl.get_rect(center=(scale_x + 26, scale_top - 16)))  # draw plus near top
    screen.blit(minus_lbl, minus_lbl.get_rect(center=(scale_x + 26, scale_bot + 16)))# draw minus near bottom

    react_lbl = font.render("Reactivity", True, BLACK)                               # render scale label
    screen.blit(react_lbl, react_lbl.get_rect(midleft=(scale_x + 48, (scale_top + scale_bot) // 2)))  # draw label centered mid-scale

    rho_span = (RHO_POS_LIMIT - RHO_NEG_LIMIT)                                       # compute total displayed rho span
    rho_frac = (rho_new - RHO_NEG_LIMIT) / max(1e-9, rho_span)                       # map rho to [0, 1] within span
    rho_frac = clamp(rho_frac, 0.0, 1.0)                                             # clamp mapped fraction
    pointer_y = scale_bot - rho_frac * (scale_bot - scale_top)                       # convert fraction to y coordinate
    pygame.draw.circle(screen, BLACK, (scale_x, int(pointer_y)), 6)                  # draw pointer dot on scale

    top_txt = small_font.render(f"{RHO_POS_LIMIT:+.3f}", True, BLACK)                # render top rho limit text
    bot_txt = small_font.render(f"{RHO_NEG_LIMIT:+.3f}", True, BLACK)                # render bottom rho limit text
    screen.blit(top_txt, (scale_x + 14, scale_top - 6))                              # draw top limit text
    screen.blit(bot_txt, (scale_x + 14, scale_bot - 12))                             # draw bottom limit text

    # Debug under lever                                                               # section header: debug line (optional)
    travel = (LEVER_TRACK_BOTTOM - LEVER_TRACK_TOP - LEVER_HEIGHT)                   # compute travel for debug calculation
    x_withdrawn = (LEVER_TRACK_BOTTOM - LEVER_HEIGHT - lever_positions[0]) / travel if travel > 0.0 else 0.0  # recompute withdrawn fraction
    x_withdrawn = clamp(x_withdrawn, 0.0, 1.0)                                       # clamp withdrawn fraction
    worth_fraction = rod_curve(x_withdrawn)                                          # recompute worth fraction
    dbg = small_font.render(                                                        # render debug string
        f"x_withdrawn={x_withdrawn:.3f}  worth_frac={worth_fraction:.3f}  rho_base={RHO_BASE:+.4f}  rho_worth={RHO_WORTH:+.4f}",  # debug text
        True, BLACK                                                                 # antialias + color
    )
    screen.blit(dbg, dbg.get_rect(midtop=(lever_x_positions[0] + 215, LEVER_TRACK_BOTTOM + 48)))  # draw debug line below lever

    # -------- DIALS --------                                                        # section header: draw dials
    for i in range(NUM_DIALS):                                                       # iterate dials
        cx, cy = dial_centers[i]                                                     # dial center coordinates
        pygame.draw.circle(screen, GREY, (cx, cy), DIAL_RADIUS + 8)                  # draw dial bezel
        face_color = DIAL_INACTIVE_COLOR if not power_on else (YELLOW if dial_active[i] else DIAL_INACTIVE_COLOR)  # choose face color
        pygame.draw.circle(screen, face_color, (cx, cy), DIAL_RADIUS)                # draw dial face
        draw_dial_ticks(cx, cy, DIAL_RADIUS)                                         # draw dial ticks and labels

        angle_rad = math.radians(angle_from_detent(dial_detents[i]))                 # compute pointer angle from detent
        line_x = cx + DIAL_RADIUS * math.cos(angle_rad)                              # compute pointer end x
        line_y = cy + DIAL_RADIUS * math.sin(angle_rad)                              # compute pointer end y
        pygame.draw.line(screen, WHITE, (cx, cy), (line_x, line_y), 4)               # draw pointer line

        cap = font.render(dial_names[i], True, BLACK)                                # render dial caption
        screen.blit(cap, cap.get_rect(center=(cx, cy - DIAL_RADIUS - 52)))           # draw caption above dial

        det_txt = small_font.render(f"det {dial_detents[i]:+d}", True, BLACK)        # render detent indicator text
        screen.blit(det_txt, det_txt.get_rect(center=(cx, cy + DIAL_RADIUS + 18)))   # draw detent text below dial

    pygame.display.flip()                                                            # update the display (swap buffers)
    clock.tick(60)                                                                   # cap loop to 60 FPS

pygame.quit()                                                                        # shut down pygame modules cleanly
sys.exit()                                                                           # exit program explicitly
