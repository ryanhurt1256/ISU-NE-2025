        fine_frac, ch2_det, ch3_det, power_sw, scram_sw = last_serial_controls     # unpack cached rod + dials + switches

        prev_lever_y = lever_positions[0]                                            # store previous lever position before applying serial
        prev_d2 = dial_detent(dial_angles[0])                                        # store previous CH2 detent before applying serial
