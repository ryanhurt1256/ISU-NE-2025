        current_power = 0.0                                                          # clear plotted power
        power_raw_display = 0.0                                                      # clear displayed uncapped power
        n = 1e-12                                                                    # reset neutron population to floor
        C = 0.0                                                                      # reset precursor concentration
        rho_prev = 0.0                                                               # reset previous reactivity
