def kinetics_rhs(state, rho):                                                       # compute kinetics ODE right-hand side
    n_s, C_s = state                                                                # unpack state (n, C)
    dn_dt = ((rho - beta) / Lambda) * n_s + lam * C_s + S_SOURCE                    # compute dn/dt (point kinetics + source)
    dC_dt = (beta / Lambda) * n_s - lam * C_s                                       # compute dC/dt (precursor balance)
    return dn_dt, dC_dt                                                             # return derivatives

def rk4_step(state, dt_sub, rho):                                                   # perform one RK4 integration step
    n0, C0 = state                                                                  # unpack initial state
    k1n, k1C = kinetics_rhs((n0, C0), rho)                                           # compute k1 derivatives
    k2n, k2C = kinetics_rhs((n0 + 0.5 * dt_sub * k1n, C0 + 0.5 * dt_sub * k1C), rho) # compute k2 derivatives
    k3n, k3C = kinetics_rhs((n0 + 0.5 * dt_sub * k2n, C0 + 0.5 * dt_sub * k2C), rho) # compute k3 derivatives
    k4n, k4C = kinetics_rhs((n0 + dt_sub * k3n, C0 + dt_sub * k3C), rho)            # compute k4 derivatives
    n_new = n0 + (dt_sub / 6.0) * (k1n + 2*k2n + 2*k3n + k4n)                       # combine slopes for n
    C_new = C0 + (dt_sub / 6.0) * (k1C + 2*k2C + 2*k3C + k4C)                       # combine slopes for C
    return n_new, C_new                                                             # return updated state

def fit_period_from_buffer(buf):                                                    # fit ln(I) vs time to estimate period
    if len(buf) < 6:                                                                # require enough samples for stability
        return float("inf")                                                         # otherwise report infinite period
    t0 = buf[0][0]                                                                  # use first timestamp as origin
    xs = [p[0] - t0 for p in buf]                                                    # build time vector relative to t0
    ys = [p[1] for p in buf]                                                        # build ln(I) vector
    xbar = sum(xs) / len(xs)                                                        # compute mean time
    ybar = sum(ys) / len(ys)                                                        # compute mean ln(I)
    num = 0.0                                                                       # numerator for slope
    den = 0.0                                                                       # denominator for slope
    for x, y in zip(xs, ys):                                                        # iterate samples
        dx = x - xbar                                                               # time deviation
        dy = y - ybar                                                               # ln(I) deviation
        num += dx * dy                                                              # accumulate covariance term
        den += dx * dx                                                              # accumulate variance term
    if den <= 1e-12:                                                                # guard against divide-by-zero
        return float("inf")                                                         # return infinite period if ill-conditioned
    slope = num / den                                                               # slope of ln(I) vs time (1/s)
    return (1.0 / slope) if slope > 0.0 else float("inf")                           # period = 1/slope for rising signal, else inf

def setup_serial(port, baud=BAUDRATE):                                              # open serial port helper
    if serial is None:                                                              # if pyserial not available
        return None                                                                 # indicate serial disabled
    try:                                                                            # attempt to open the port
        s = serial.Serial(port, baud, timeout=0.05)                                 # create Serial object (non-blocking-ish)
        time.sleep(1.0)                                                             # allow Arduino to reset / settle
        return s                                                                    # return open serial handle
    except Exception:                                                               # on any open error
        return None                                                                 # return None so we can try next port

ser = None                                                                          # serial handle (None until opened)
for port in ("/dev/ttyACM0", "/dev/ttyACM1", "/dev/ttyUSB0", "/dev/ttyUSB1", "/dev/serial0"):  # candidate device paths
    ser = setup_serial(port)                                                        # try opening this port
    if ser is not None:                                                             # if successful
        break                                                                       # stop searching ports

def read_controls_from_serial(ser_obj):                                             # read and parse one control packet
    if ser_obj is None:                                                             # if no serial object
        return None                                                                 # no data available
    try:                                                                            # protect parsing from exceptions
        raw = ser_obj.readline().decode(errors="ignore").strip()                    # read one line, decode bytes, strip whitespace
        if not raw:                                                                 # if empty line
            return None                                                             # treat as no new data
        parts = raw.split(",")                                                      # split CSV fields
        if len(parts) < 5:                                                          # require 5 fields minimum
            return None                                                             # ignore malformed lines
        fine = float(parts[0])                                                      # parse rod fraction (0..1)
        ch2_det = int(float(parts[1]))                                              # parse CH2 detent (-3..+3)
        ch3_det = int(float(parts[2]))                                              # parse CH3 detent (-3..+3)
        power_sw = bool(int(float(parts[3])))                                       # parse power switch (0/1) -> bool
        scram_sw = bool(int(float(parts[4])))                                       # parse scram switch (0/1) -> bool

        fine = clamp(fine, 0.0, 1.0)                                                # clamp rod fraction to [0, 1]
        ch2_det = clamp(ch2_det, -3, 3)                                             # clamp CH2 detent to [-3, +3]
        ch3_det = clamp(ch3_det, -3, 3)                                             # clamp CH3 detent to [-3, +3]
        return fine, ch2_det, ch3_det, power_sw, scram_sw                           # return parsed controls tuple
    except Exception:                                                               # if parsing fails for any reason
        return None                                                                 # treat as no valid data

def draw_ticks_and_labels():                                                        # draw axis ticks and dial-dependent labels
    font = pygame.font.SysFont(None, 20)                                            # create font for tick labels
    linear_width = GRAPH_WIDTH // 2                                                 # split graph into left/right halves
    right_start = GRAPH_X + linear_width                                            # x coordinate where right half starts

    # CH2 LOG                                                                          # section: CH2 log ticks
    det2 = dial_detents[0]                                                          # current CH2 detent
    ch2_log_max = CH2_LOG_MAX_AT_0 + det2                                           # compute log10 max based on detent
    ch2_log_min = ch2_log_max - CH2_LOG_SPAN_DECADES                                # compute log10 min based on span

    d0 = int(math.floor(ch2_log_min))                                               # first decade to label
    d1 = int(math.ceil(ch2_log_max))                                                # last decade to label
    for decade in range(d0, d1 + 1):                                                # iterate decades for tick marks
        frac = (ch2_log_max - decade) / max(1e-9, (ch2_log_max - ch2_log_min))      # map decade to [0, 1] across window
        frac = clamp(frac, 0.0, 1.0)                                                # clamp fraction to visible region
        x = GRAPH_X + frac * linear_width                                           # compute x position of tick
        y = GRAPH_Y + GRAPH_HEIGHT                                                  # compute y position at bottom axis
        pygame.draw.line(screen, BLACK, (x, y), (x, y + 8), 2)                      # draw the bottom tick mark
        if x < (GRAPH_X + linear_width - 28):                                       # avoid label clipping near right edge
            lbl = font.render(f"10^{decade}", True, BLACK)                          # render decade label as 10^N
            screen.blit(lbl, lbl.get_rect(center=(x, y + 22)))                      # draw label under tick

    # CH3 LIN                                                                          # section: CH3 linear ticks
    det3 = dial_detents[1]                                                          # current CH3 detent
    fs3 = CH3_RANGES[det3 + 3]                                                      # full-scale current for this detent
    for frac, lbl in [(0.0, "0"), (0.5, "0.5FS"), (1.0, "FS")]:                     # draw 0, half-scale, full-scale ticks
        x = right_start + frac * linear_width                                       # compute x tick location on right half
        y = GRAPH_Y + GRAPH_HEIGHT                                                  # y at bottom axis
        pygame.draw.line(screen, BLACK, (x, y), (x, y + 8), 2)                      # draw tick mark
        if frac > 0.0:                                                              # skip labeling the origin (already implied)
            t = font.render(lbl, True, BLACK)                                       # render tick label
            screen.blit(t, t.get_rect(center=(x, y + 22)))                          # draw label under tick
    fs_text = font.render(f"CH3 FS={format_amps(fs3)}", True, BLACK)                # show the current CH3 full-scale value
    screen.blit(fs_text, (right_start + 10, GRAPH_Y + GRAPH_HEIGHT + 10))           # draw FS text near the bottom right

    # Y ticks                                                                          # section: vertical time index ticks
    max_time = power_history.maxlen                                                 # number of samples in buffers (max)
    for tick in range(0, max_time + 1, 50):                                         # label every 50 indices
        y = GRAPH_Y + (tick / max_time) * GRAPH_HEIGHT                              # compute y position for tick
        pygame.draw.line(screen, BLACK, (GRAPH_X - 8, y), (GRAPH_X, y), 2)          # draw left-side tick mark
        label = font.render(str(tick), True, BLACK)                                 # render tick number
        screen.blit(label, label.get_rect(center=(GRAPH_X - 28, y)))                # draw label left of axis

