        power_history.clear()                                                        # clear power plot history
        ch2_history.clear()                                                          # clear CH2 plot history
        ch3_history.clear()                                                          # clear CH3 plot history
        ch3_period_s = float("inf")                                                  # reset computed period
        ch3_ln_buf.clear()                                                           # clear period fitting buffer
        ch3_period_bad_time = 0.0                                                    # reset persistent-fast accumulator
        ch2_hi_lockout = False                                                       # clear CH2 lockout
        lever_positions[:] = [LEVER_TRACK_BOTTOM - LEVER_HEIGHT] * NUM_LEVERS        # reset lever to bottom position (single)
