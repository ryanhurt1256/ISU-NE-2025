        angle_rad = math.radians(angle_deg)                                          # convert degrees to radians for trig
        tick_len = 10 if i == 3 else 6                                               # make center tick longer for emphasis
        label_txt = "0" if i == 3 else str(i - 3)                                    # label center as 0, others as -3..+3
        outer_x = cx + radius * math.cos(angle_rad)                                  # compute outer tick x coordinate
        outer_y = cy + radius * math.sin(angle_rad)                                  # compute outer tick y coordinate
        inner_x = cx + (radius - tick_len) * math.cos(angle_rad)                     # compute inner tick x coordinate
        inner_y = cy + (radius - tick_len) * math.sin(angle_rad)                     # compute inner tick y coordinate
