def first_order_lag(y, x, dt, tau):                                                  # compute 1st-order lag filter output
    if tau <= 1e-6:                                                                  # if tau is ~0, filtering is unnecessary
        return x                                                                     # return input directly (no lag)
    alpha = dt / (tau + dt)                                                          # compute blend factor for stable discretization
    return y + alpha * (x - y)                                                       # update output toward input with first-order dynamics

def dial_detent(angle_deg):                                                          # convert dial angle (deg) to detent integer
    d = int(round((angle_deg - (-90.0)) / 30.0))                                     # compute detent based on 30° increments
    return max(-3, min(3, d))                                                        # clamp detent to the allowed range [-3, +3]

def angle_from_detent(det):                                                          # convert detent integer back to dial angle (deg)
    return -90.0 + 30.0 * float(det)                                                 # map detent to -90° + 30°*detent

def format_amps(I):                                                                  # format current value into human-readable units
    I = float(I)                                                                     # coerce to float for safe formatting
    a = abs(I)                                                                       # compute magnitude for unit selection
    if a >= 1e-6:                                                                    # if magnitude is at least microamps
        return f"{I/1e-6:.2f} µA"                                                    # format as microamps
    if a >= 1e-9:                                                                    # if magnitude is at least nanoamps
        return f"{I/1e-9:.2f} nA"                                                    # format as nanoamps
    if a >= 1e-12:                                                                   # if magnitude is at least picoamps
        return f"{I/1e-12:.2f} pA"                                                   # format as picoamps
    return f"{I:.2e} A"                                                              # otherwise use scientific notation in amps

def rod_curve(x):                                                                    # nonlinear rod worth fraction vs insertion fraction
    a = 3.3                                                                          # curve shape constant (your calibration parameter)
    return 1.0 - math.exp(-a * x)                                                    # compute fractional worth: 1 - exp(-a x)

def smooth_points(points, steps=6):                                                  # densify a polyline for smoother rendering
    smoothed = []                                                                    # create output list of points
    if len(points) < 2:                                                              # if fewer than 2 points, nothing to smooth
        return points                                                                # return input points unchanged
    for i in range(len(points) - 1):                                                 # iterate over each line segment
        x1, y1 = points[i]                                                           # unpack segment start point
        x2, y2 = points[i + 1]                                                       # unpack segment end point
        for t in range(steps):                                                       # insert intermediate points along segment
            alpha = t / steps                                                        # compute interpolation fraction in [0,1)
            smoothed.append((x1 * (1 - alpha) + x2 * alpha,                          # interpolate x coordinate
                             y1 * (1 - alpha) + y2 * alpha))                         # interpolate y coordinate
    smoothed.append(points[-1])                                                      # append the last original point
    return smoothed                                                                  # return the smoothed point list

