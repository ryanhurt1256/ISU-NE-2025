            if power_on and not scram_active:                                        # allow selecting controls only if running
                lever_clicked = False                                                # initialize “clicked a lever” flag
                for i, x in enumerate(lever_x_positions):                            # iterate each lever x position with index (only 1)
                    if (x - 14 < mx < x + 14 and                                     # check x within lever handle width
                        lever_positions[i] < my < lever_positions[i] + LEVER_HEIGHT):# check y within lever handle bounds
                        lever_clicked = True                                         # mark that a lever was clicked
                        lever_active[:] = [False] * NUM_LEVERS                       # clear all lever active highlights
