def smooth_points(points, steps=6):                                                 # densify polyline points for smoother look
    if len(points) < 2:                                                             # if not enough points
        return points                                                               # return unchanged
    out = []                                                                        # allocate output list
    for i in range(len(points) - 1):                                                # iterate adjacent point pairs
        x1, y1 = points[i]                                                          # unpack first point
        x2, y2 = points[i + 1]                                                      # unpack second point
        for t in range(steps):                                                      # add intermediate points
            a = t / steps                                                           # interpolation fraction
            out.append((x1 * (1 - a) + x2 * a, y1 * (1 - a) + y2 * a))              # append interpolated point
    out.append(points[-1])                                                          # add final point
    return out                                                                      # return smoothed list

