def fit_period_from_buffer(buf):                                                     # estimate reactor period from ln(I) vs time slope
    if len(buf) < 6:                                                                 # require enough samples to fit reliably
        return float("inf")                                                          # return infinity if insufficient data
    t0 = buf[0][0]                                                                   # take first timestamp as reference
    xs = [p[0] - t0 for p in buf]                                                    # compute time offsets relative to t0
    ys = [p[1] for p in buf]                                                         # collect ln(I) values
    xbar = sum(xs) / len(xs)                                                         # compute mean time offset
    ybar = sum(ys) / len(ys)                                                         # compute mean ln(I)
    num = 0.0                                                                        # initialize covariance numerator
    den = 0.0                                                                        # initialize variance denominator
    for x, y in zip(xs, ys):                                                         # iterate paired samples
        dx = x - xbar                                                                # compute x deviation from mean
        dy = y - ybar                                                                # compute y deviation from mean
        num += dx * dy                                                               # accumulate covariance term
        den += dx * dx                                                               # accumulate variance term
    if den <= 1e-12:                                                                 # protect against divide-by-zero (flat time)
        return float("inf")                                                          # return infinity if slope cannot be computed
    slope = num / den                                                                # compute slope d(ln I)/dt
    return (1.0 / slope) if slope > 0.0 else float("inf")                            # convert slope to period (seconds) for rising signal

