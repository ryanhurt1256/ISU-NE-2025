        a = 3.3                                                                       # must match rod_curve()
        f1 = 1.0 - math.exp(-a * 1.0)                                                 # rod_curve(1.0): max worth fraction over full travel
        target = frac_in * f1                                                         # desired worth fraction at this lever position
        frac_eff = -(1.0 / a) * math.log(max(1e-12, 1.0 - target))                    # inverse map: rod_curve(frac_eff) == target
        worth_fraction = rod_curve(frac_eff)                                          # now worth_fraction tracks lever travel linearly

        rho_new = (2.0 * worth_fraction - 1.0) * rho_fine                            # map to [-worth,+worth] for fine rod only  # fine-only

        RHO_POS_LIMIT = 0.90 * beta                                                  # set positive reactivity clamp (safer low-power control) this might need to be adjusted for physical rod
        RHO_NEG_LIMIT = -0.2                                                         # set negative reactivity clamp (shutdown margin)
