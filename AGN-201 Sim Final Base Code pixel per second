            logI = math.log10(max(I, I_FLOOR))                                       # compute log10 of current (protected by floor)
            frac = (logI - ch2_log_min) / max(1e-9, (ch2_log_max - ch2_log_min))     # normalize into [0,1] across window
            frac = max(0.0, min(1.0, frac))                                          # clamp into [0,1]
