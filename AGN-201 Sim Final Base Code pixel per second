        if abs(rho_new - rho_prev) > 1e-5:                                           # apply prompt-jump smoothing if rho changed noticeably
            denom_j = (beta - rho_new)                                               # compute denominator for prompt jump scaling
            denom_j = denom_j if abs(denom_j) >= 1e-6 else (1e-6 if denom_j >= 0 else -1e-6)  # protect denominator from zero
            raw_jump = (beta - rho_prev) / denom_j                                   # compute raw prompt jump factor
            raw_jump = max(0.8, min(1.2, raw_jump))                                  # clamp jump factor to limit numerical spikes
            jump_factor = 1.0 + 0.5 * (raw_jump - 1.0)                               # soften jump by scaling toward 1.0
            n = max(1e-12, n * jump_factor)                                          # apply jump to neutron population and enforce floor

        substeps = 12                                                                # choose RK4 substeps per frame for stability
        dt_sub = dt / max(1, substeps)                                               # compute per-substep dt
        for _ in range(substeps):                                                    # integrate across all substeps this frame
            n, C = rk4_step((n, C), dt_sub, rho_new)                                 # advance (n,C) by one RK4 substep
            n = 1e-12 if (not (n == n) or n < 1e-12) else n                          # guard against NaN/negative n (keep floor)
            C = 0.0 if (not (C == C) or C < 0.0) else C                              # guard against NaN/negative C (keep nonnegative)

        power_raw = max(0.0, P_SCALE * n)                                            # compute physical (uncapped) power estimate
        power_raw_display = power_raw                                                # store uncapped power for numeric display
