        lnI3 = math.log(max(ch3_I_ind, I_FLOOR))                                     # compute ln(CH3 current) for period fit
        ch3_ln_buf.append((now, lnI3))                                               # append (time, lnI) sample to buffer
        while len(ch3_ln_buf) > 0 and (now - ch3_ln_buf[0][0]) > CH3_PERIOD_FIT_WINDOW_S:  # enforce window length on buffer
