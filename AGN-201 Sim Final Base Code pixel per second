        ch3_I_ind = first_order_lag(ch3_I_ind, I_FLOOR, dt, 0.5)                     # decay CH3 indication toward floor
        ch3_period_s = float("inf")                                                  # set period to infinity (undefined)
        ch3_ln_buf.clear()                                                           # clear period buffer so fit restarts clean
        ch3_period_bad_time = 0.0                                                    # reset period bad-time accumulator

    # -------------------------                                                      # section divider: plots
    # PLOTS (LEFT = CH2 LOG, RIGHT = CH3 LIN)                                        # plot assignment labels
    # -------------------------                                                      # end section divider
    pygame.draw.rect(screen, GREY, (GRAPH_X, GRAPH_Y, GRAPH_WIDTH, GRAPH_HEIGHT))    # draw plot background rectangle
    linear_width = GRAPH_WIDTH // 2                                                        # compute half-width for split plots
    right_start = GRAPH_X + linear_width                                                   # compute x start of right plot half

