def kinetics_rhs(state, rho):                                                        # compute point-kinetics derivatives for (n, C)
    n_s, C_s = state                                                                 # unpack neutron population and precursor concentration
    dn_dt = ((rho - beta) / Lambda) * n_s + lam * C_s + S_SOURCE                     # compute dn/dt including delayed and source terms
    dC_dt = (beta / Lambda) * n_s - lam * C_s                                        # compute dC/dt (production minus decay)
    return dn_dt, dC_dt                                                              # return time derivatives (dn/dt, dC/dt)

def rk4_step(state, dt_sub, rho):                                                    # integrate one RK4 step for point kinetics
    n0, C0 = state                                                                   # unpack state at start of step
    k1n, k1C = kinetics_rhs((n0, C0), rho)                                            # compute k1 derivatives
    k2n, k2C = kinetics_rhs((n0 + 0.5 * dt_sub * k1n,                                 # compute state for k2 (n midpoint)
                             C0 + 0.5 * dt_sub * k1C), rho)                          # compute state for k2 (C midpoint)
    k3n, k3C = kinetics_rhs((n0 + 0.5 * dt_sub * k2n,                                 # compute state for k3 (n midpoint)
                             C0 + 0.5 * dt_sub * k2C), rho)                          # compute state for k3 (C midpoint)
    k4n, k4C = kinetics_rhs((n0 + dt_sub * k3n,                                       # compute state for k4 (n endpoint)
                             C0 + dt_sub * k3C), rho)                                # compute state for k4 (C endpoint)
    n_new = n0 + (dt_sub / 6.0) * (k1n + 2 * k2n + 2 * k3n + k4n)                     # combine slopes to update n
    C_new = C0 + (dt_sub / 6.0) * (k1C + 2 * k2C + 2 * k3C + k4C)                     # combine slopes to update C
    return n_new, C_new                                                              # return updated (n, C)

BAUDRATE = 115200                                                                    # set serial baud rate (must match microcontroller)

def setup_serial(port, baud=BAUDRATE):                                               # open serial connection to given device path
    if serial is None:                                                               # if pyserial is unavailable
        return None                                                                  # return None (serial disabled)
    try:                                                                             # attempt to open serial port
        ser = serial.Serial(port, baud, timeout=0.05)                                # open port with short non-blocking timeout
        time.sleep(1.0)                                                              # wait for MCU auto-reset after serial open
        return ser                                                                   # return live serial object
    except Exception:                                                                # if opening fails for any reason
        return None                                                                  # return None to continue without serial

ser = None                                                                           # initialize serial handle as None (disconnected)
for port in ("/dev/ttyUSB0", "/dev/ttyACM0", "/dev/serial0"):                        # try common Raspberry Pi serial device names
    ser = setup_serial(port)                                                         # attempt to connect on this port
    if ser is not None:                                                              # if connection succeeded
        break                                                                        # stop trying more ports

def read_controls_from_serial(ser):                                                  # read and parse one line of control data
    if ser is None:                                                                  # if serial is not connected
        return None                                                                  # return None to indicate no update
    try:                                                                             # try reading and parsing the line
        raw = ser.readline().decode(errors="ignore").strip()                         # read one line, decode bytes, strip whitespace
        if not raw:                                                                  # if line is empty (no data)
            return None                                                              # return None to indicate no update
        parts = raw.split(",")                                                       # split comma-separated values into fields
        if len(parts) < 6:                                                           # require at least 6 fields (legacy format still supported)
            return None                                                              # reject malformed packet
        rods = [float(p) for p in parts[:4]]                                         # parse rod fractions (expected 0.0..1.0)
        power_sw = bool(int(float(parts[4])))                                        # parse power switch as boolean (0/1)
        scram_sw = bool(int(float(parts[5])))                                        # parse scram switch as boolean (0/1)
        coarse = rods[3] if len(rods) >= 4 else 0.0                                  # extract coarse rod fraction safely (legacy)  # coarse-only
        return coarse, power_sw, scram_sw                                            # return coarse-only value plus switches  # coarse-only
    except Exception:                                                                # ignore any parse/IO errors safely
        return None                                                                  # return None on error to avoid crashing

