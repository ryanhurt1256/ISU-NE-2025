        label = font.render(str(time_tick), True, BLACK)                             # render tick label text
        screen.blit(label, label.get_rect(center=(GRAPH_X - 28, y)))                 # draw label left of the tick

def fit_period_from_buffer(buf):                                                     # estimate reactor period from ln(I) vs time slope
    if len(buf) < 6:                                                                 # require enough samples to fit reliably
        return float("inf")                                                          # return infinity if insufficient data
    t0 = buf[0][0]                                                                   # take first timestamp as reference
    xs = [p[0] - t0 for p in buf]                                                    # compute time offsets relative to t0
    ys = [p[1] for p in buf]                                                         # collect ln(I) values
    xbar = sum(xs) / len(xs)                                                         # compute mean time offset
    ybar = sum(ys) / len(ys)                                                         # compute mean ln(I)
    num = 0.0                                                                        # initialize covariance numerator
    den = 0.0                                                                        # initialize variance denominator
    for x, y in zip(xs, ys):                                                         # iterate paired samples
        dx = x - xbar                                                                # compute x deviation from mean
        dy = y - ybar                                                                # compute y deviation from mean
        num += dx * dy                                                               # accumulate covariance term
        den += dx * dx                                                               # accumulate variance term
    if den <= 1e-12:                                                                 # protect against divide-by-zero (flat time)
        return float("inf")                                                          # return infinity if slope cannot be computed
    slope = num / den                                                                # compute slope d(ln I)/dt
    return (1.0 / slope) if slope > 0.0 else float("inf")                            # convert slope to period (seconds) for rising signal

running = True                                                                       # set main loop run flag
while running:                                                                       # main event/physics/render loop
    screen.fill(WHITE)                                                               # clear the screen background
    now = time.time()                                                                # read current wall time
    dt = now - last_time                                                             # compute frame delta time (seconds)
    if dt <= 0.0:                                                                    # protect against zero/negative dt (rare)
        dt = 1.0 / 60.0                                                              # default dt to ~60 FPS
    if dt > 0.1:                                                                     # clamp dt to avoid huge physics jumps on lag
        dt = 0.1                                                                     # set maximum dt
    last_time = now                                                                  # update last_time for next frame

    serial_controls = read_controls_from_serial(ser)                                 # read one serial packet (if available)
    if serial_controls:                                                              # if a valid packet was parsed
        coarse_frac, power_sw, scram_sw = serial_controls                            # unpack coarse rod fraction and switches  # coarse-only
        travel = (LEVER_TRACK_BOTTOM - LEVER_TRACK_TOP - LEVER_HEIGHT)               # compute lever travel distance (pixels)
        frac = max(0.0, min(1.0, float(coarse_frac)))                                # clamp coarse rod fraction to [0,1]  # coarse-only
        lever_positions[0] = LEVER_TRACK_TOP + frac * travel                         # map fraction -> single lever y position  # coarse-only

        if power_sw and not power_on:                                                # detect power switch rising edge
            power_on = True                                                          # set power state to on
            power_on_time = now                                                      # record power-on timestamp
            scram_active = False                                                     # clear SCRAM state
            scram_start_time = 0.0                                                   # clear SCRAM timer
            current_power = 1.0                                                      # initialize displayed power to 1 W
            power_raw_display = 1.0                                                  # initialize uncapped power display to 1 W
            n = max(1e-12, current_power / P_SCALE)                                  # initialize neutron population from power
            C = (beta / (Lambda * lam)) * n                                          # initialize precursor at steady-state for n
            dial_angles[0] = angle_from_detent(2)                                    # set CH2 dial to startup detent +2
            dial_angles[1] = angle_from_detent(1)                                    # set CH3 dial to startup detent +1
            reset_instruments_to_power(current_power)                                # reset instrument histories and states
            power_history.clear()                                                    # clear power plot history
            last_control_move_time = now                                             # inhibit scrams immediately after power-on

        if (not power_sw) and power_on:                                              # detect power switch falling edge while on
            scram_active = True                                                      # trigger SCRAM state
            scram_start_time = now                                                   # record SCRAM start time

        if scram_sw:                                                                 # if external SCRAM switch is asserted
            scram_active = True                                                      # trigger SCRAM state
            scram_start_time = now                                                   # record SCRAM start time

    for event in pygame.event.get():                                                 # poll and handle pygame events
        if event.type == pygame.QUIT:                                                # if window close is requested
            running = False                                                          # stop the main loop
        elif event.type == pygame.MOUSEBUTTONDOWN:                                   # if mouse button pressed
            mx, my = event.pos                                                       # get mouse x,y position

            if power_button_rect.collidepoint((mx, my)):                             # if POWER button clicked
                if power_on:                                                         # if already on
                    scram_active = True                                              # treat power-off click as SCRAM action
                    scram_start_time = now                                           # record SCRAM start time
                else:                                                                # if currently off
                    power_on = True                                                  # set power state to on
                    power_on_time = now                                              # record power-on timestamp
                    scram_active = False                                             # clear SCRAM state
                    scram_start_time = 0.0                                           # clear SCRAM timer
                    current_power = 1.0                                              # initialize displayed power to 1 W
                    power_raw_display = 1.0                                          # initialize uncapped power display to 1 W
                    n = max(1e-12, current_power / P_SCALE)                          # initialize neutron population from power
                    C = (beta / (Lambda * lam)) * n                                  # initialize precursor at steady-state for n
                    dial_angles[0] = angle_from_detent(2)                            # set CH2 dial to startup detent +2
                    dial_angles[1] = angle_from_detent(1)                            # set CH3 dial to startup detent +1
                    reset_instruments_to_power(current_power)                        # reset instrument histories and states
                    power_history.clear()                                            # clear power plot history
                    last_control_move_time = now                                     # inhibit scrams immediately after power-on
                continue                                                             # skip further selection logic after POWER click

            if scram_button_rect.collidepoint((mx, my)):                             # if SCRAM button clicked
                if power_on:                                                         # only allow SCRAM if system is powered
                    scram_active = True                                              # trigger SCRAM state
                    scram_start_time = now                                           # record SCRAM start time
                continue                                                             # skip selection logic after SCRAM click

            if power_on and not scram_active:                                        # allow selecting controls only if running
                lever_clicked = False                                                # initialize “clicked a lever” flag
                for i, x in enumerate(lever_x_positions):                            # iterate each lever x position with index (only 1)
                    if (x - 14 < mx < x + 14 and                                     # check x within lever handle width
                        lever_positions[i] < my < lever_positions[i] + LEVER_HEIGHT):# check y within lever handle bounds
                        lever_clicked = True                                         # mark that a lever was clicked
                        lever_active[:] = [False] * NUM_LEVERS                       # clear all lever active highlights
                        dial_active[:]  = [False] * NUM_DIALS                        # clear all dial active highlights
                        selected_dial = None                                         # clear dial selection
                        selected_lever = i                                           # select this (only) lever index
                        lever_active[i] = True                                       # set this lever as active/highlighted
                        lever_activation_time[i] = now                               # stamp last interaction time
                        break                                                        # stop searching once a lever is selected
                if not lever_clicked:                                                # if no lever was selected by the click
                    for i, (cx, cy) in enumerate(dial_centers):                      # iterate each dial center with index
                        if math.hypot(mx - cx, my - cy) < DIAL_RADIUS + 12:          # radial hit-test (click inside dial)
                            lever_active[:] = [False] * NUM_LEVERS                   # clear lever active highlights
                            dial_active[:]  = [False] * NUM_DIALS                    # clear dial active highlights
                            selected_lever = None                                    # clear lever selection
                            selected_dial = i                                        # select this dial index
                            dial_active[i] = True                                    # set this dial as active/highlighted
                            dial_activation_time[i] = now                            # stamp last interaction time
                            break                                                    # stop searching once a dial is selected

    keys = pygame.key.get_pressed()                                                  # read keyboard state snapshot
    moved_this_frame = False                                                         # track whether any control moved this frame

    if power_on and not scram_active:                                                # allow movement only when running and not scrammed
        if selected_lever is not None and lever_active[selected_lever]:              # if a lever is selected and active
            if keys[pygame.K_UP]:                                                    # if up arrow is held
                lever_positions[selected_lever] -= LEVER_SPEED_PX                     # move lever up by LEVER_SPEED_PX pixels
                lever_activation_time[selected_lever] = now                          # update last interaction time
                moved_this_frame = True                                              # record that movement occurred
            elif keys[pygame.K_DOWN]:                                                # if down arrow is held
                lever_positions[selected_lever] += LEVER_SPEED_PX                     # move lever down by LEVER_SPEED_PX pixels
                lever_activation_time[selected_lever] = now                          # update last interaction time
                moved_this_frame = True                                              # record that movement occurred

            lever_positions[selected_lever] = max(                                   # clamp lever position to valid track range
                LEVER_TRACK_TOP,                                                     # upper bound (fully up)
                min(LEVER_TRACK_BOTTOM - LEVER_HEIGHT,                               # lower bound (fully down)
                    lever_positions[selected_lever])                                  # current lever position
            )                                                                        # close clamp expression

        if selected_dial is not None and dial_active[selected_dial]:                 # if a dial is selected and active
            prev_det = dial_detent(dial_angles[selected_dial])                       # compute detent before movement
            if keys[pygame.K_LEFT]:                                                  # if left arrow is held
                dial_angles[selected_dial] -= 2                                      # rotate dial left by small increment (degrees)
                dial_activation_time[selected_dial] = now                            # update last interaction time
            elif keys[pygame.K_RIGHT]:                                               # if right arrow is held
                dial_angles[selected_dial] += 2                                      # rotate dial right by small increment (degrees)
                dial_activation_time[selected_dial] = now                            # update last interaction time
            new_det = dial_detent(dial_angles[selected_dial])                        # compute detent after movement
            if new_det != prev_det:                                                  # only count a “move” when detent changes
                moved_this_frame = True                                              # record movement occurred (for inhibit timer)

    if moved_this_frame:                                                             # if any control moved in this frame
        last_control_move_time = now                                                 # update last control movement timestamp

    for i in range(NUM_LEVERS):                                                      # loop over levers for cooldown handling (only 1)
        if lever_active[i] and (now - lever_activation_time[i]) > COOLDOWN_TIME:     # if lever has been idle past cooldown
            lever_active[i] = False                                                  # deactivate lever highlight
            if selected_lever == i:                                                  # if that lever was selected
                selected_lever = None                                                # clear lever selection

    for i in range(NUM_DIALS):                                                       # loop over dials for cooldown handling
        if dial_active[i] and (now - dial_activation_time[i]) > COOLDOWN_TIME:       # if dial has been idle past cooldown
            dial_active[i] = False                                                   # deactivate dial highlight
            if selected_dial == i:                                                   # if that dial was selected
                selected_dial = None                                                 # clear dial selection

    if scram_active:                                                                 # if SCRAM is active
        for i in range(NUM_LEVERS):                                                  # iterate all levers (only 1)
            lever_positions[i] = LEVER_TRACK_BOTTOM - LEVER_HEIGHT                   # force lever fully down (insertion)

    if scram_active and (now - scram_start_time > 3.0):                              # if SCRAM has elapsed beyond reset time
        power_on = False                                                             # turn power off after SCRAM sequence
        scram_active = False                                                         # clear SCRAM state
        scram_start_time = 0.0                                                       # clear SCRAM timer
        current_power = 0.0                                                          # clear plotted power
        power_raw_display = 0.0                                                      # clear displayed uncapped power
        n = 1e-12                                                                    # reset neutron population to floor
        C = 0.0                                                                      # reset precursor concentration
        rho_prev = 0.0                                                               # reset previous reactivity
        rho_new = 0.0                                                                # reset current reactivity
        power_history.clear()                                                        # clear power plot history
        ch2_history.clear()                                                          # clear CH2 plot history
        ch3_history.clear()                                                          # clear CH3 plot history
        ch2_period_s = float("inf")                                                  # reset computed period
        ch2_ln_buf.clear()                                                           # clear period fitting buffer
        ch2_period_bad_time = 0.0                                                    # reset persistent-fast accumulator
        lever_positions[:] = [LEVER_TRACK_BOTTOM - LEVER_HEIGHT] * NUM_LEVERS        # reset lever to bottom position (single)
        dial_angles[0] = angle_from_detent(2)                                        # reset CH2 dial to startup detent
        dial_angles[1] = angle_from_detent(1)                                        # reset CH3 dial to startup detent
        selected_lever = None                                                        # clear lever selection
        selected_dial = None                                                         # clear dial selection
        lever_active[:] = [False] * NUM_LEVERS                                       # clear lever active flags
        dial_active[:] = [False] * NUM_DIALS                                         # clear dial active flags
        last_control_move_time = now                                                 # inhibit scrams immediately after reset

    if power_on and not scram_active:                                                # run kinetics only when powered and not scrammed
        rho_coarse = 0.01250                                                         # coarse rod worth magnitude (reactivity units)  # coarse-only
        travel = (LEVER_TRACK_BOTTOM - LEVER_TRACK_TOP - LEVER_HEIGHT)               # compute travel distance for fraction mapping
        rho_new = 0.0                                                                # reset reactivity sum for this frame

        frac_in = (LEVER_TRACK_BOTTOM - LEVER_HEIGHT - lever_positions[0]) / travel if travel > 0.0 else 0.0      # insertion fraction (single)
        frac_in = max(0.0, min(1.0, frac_in))                                        # clamp insertion fraction to [0,1]
        worth_fraction = rod_curve(frac_in)                                          # compute nonlinear worth fraction from insertion
        rho_new = (2.0 * worth_fraction - 1.0) * rho_coarse                          # map to [-worth,+worth] for coarse rod only  # coarse-only

        RHO_POS_LIMIT = 0.60 * beta                                                  # set positive reactivity clamp (safer low-power control)
        RHO_NEG_LIMIT = -0.2                                                         # set negative reactivity clamp (shutdown margin)
        rho_new = max(RHO_NEG_LIMIT, min(RHO_POS_LIMIT, rho_new))                    # clamp rho to avoid unstable/extreme reactivity

        if abs(rho_new - rho_prev) > 1e-5:                                           # apply prompt-jump smoothing if rho changed noticeably
            denom_j = (beta - rho_new)                                               # compute denominator for prompt jump scaling
            denom_j = denom_j if abs(denom_j) >= 1e-6 else (1e-6 if denom_j >= 0 else -1e-6)  # protect denominator from zero
            raw_jump = (beta - rho_prev) / denom_j                                   # compute raw prompt jump factor
            raw_jump = max(0.8, min(1.2, raw_jump))                                  # clamp jump factor to limit numerical spikes
            jump_factor = 1.0 + 0.5 * (raw_jump - 1.0)                               # soften jump by scaling toward 1.0
            n = max(1e-12, n * jump_factor)                                          # apply jump to neutron population and enforce floor

        substeps = 12                                                                # choose RK4 substeps per frame for stability
        dt_sub = dt / max(1, substeps)                                               # compute per-substep dt
        for _ in range(substeps):                                                    # integrate across all substeps this frame
            n, C = rk4_step((n, C), dt_sub, rho_new)                                 # advance (n,C) by one RK4 substep
            n = 1e-12 if (not (n == n) or n < 1e-12) else n                          # guard against NaN/negative n (keep floor)
            C = 0.0 if (not (C == C) or C < 0.0) else C                              # guard against NaN/negative C (keep nonnegative)

        power_raw = max(0.0, P_SCALE * n)                                            # compute physical (uncapped) power estimate
        power_raw_display = power_raw                                                # store uncapped power for numeric display
        current_power = max(0.0, min(MAX_POWER, power_raw))                          # cap only the plotted power for graph visibility
        power_history.append(current_power)                                          # append plotted power to history buffer

        ch2_I_true = max(I_FLOOR, I_PER_WATT_CH2 * power_raw)                        # compute true CH2 current from uncapped power
        ch3_I_true = max(I_FLOOR, I_PER_WATT_CH3 * power_raw)                        # compute true CH3 current from uncapped power
        ch2_I_ind = first_order_lag(ch2_I_ind, ch2_I_true, dt, CH2_TAU)              # apply CH2 instrument lag model
        ch3_I_ind = first_order_lag(ch3_I_ind, ch3_I_true, dt, CH3_TAU)              # apply CH3 instrument lag model

        lnI = math.log(max(ch2_I_ind, I_FLOOR))                                      # compute ln(CH2 current) for period fit
        ch2_ln_buf.append((now, lnI))                                                # append (time, lnI) sample to buffer
        while len(ch2_ln_buf) > 0 and (now - ch2_ln_buf[0][0]) > CH2_PERIOD_FIT_WINDOW_S:  # discard samples older than fit window
            ch2_ln_buf.popleft()                                                     # remove oldest sample until within window
        ch2_period_s = fit_period_from_buffer(ch2_ln_buf)                            # estimate reactor period from buffer samples

        ch2_history.append(ch2_I_ind)                                                # record CH2 indicated current history
        ch3_history.append(ch3_I_ind)                                                # record CH3 indicated current history

        grace = (now - power_on_time) < SCRAM_GRACE_S                                # compute startup grace flag for scram inhibition
        moving_inhibit = (now - last_control_move_time) < CONTROL_MOVE_INHIBIT_S     # compute inhibit flag after recent movement

        scram_trip = False                                                           # initialize scram trip flag for this frame

        if (not grace) and (ch2_I_ind <= CH2_LOW_SCRAM_A):                           # check CH2 low-current scram condition
            scram_trip = True                                                        # mark scram trip
        if (not grace) and (ch2_I_ind >= CH2_HIGH_SCRAM_A):                          # check CH2 high-current scram condition
            scram_trip = True                                                        # mark scram trip

        if (not grace) and (not moving_inhibit) and (ch2_period_s != float("inf")): # check period only if enabled and finite
            if ch2_period_s <= CH2_PERIOD_SCRAM_S:                                   # if computed period is faster than threshold
                ch2_period_bad_time += dt                                            # accumulate time in “bad period” state
            else:                                                                    # if period is not bad
                ch2_period_bad_time = max(0.0, ch2_period_bad_time - 2.0 * dt)       # decay accumulator faster than it grows
        else:                                                                        # if grace or inhibit is active
            ch2_period_bad_time = 0.0                                                # reset accumulator during inhibited periods

        if (not grace) and (not moving_inhibit) and (ch2_period_bad_time >= CH2_PERIOD_PERSIST_S):  # persistent fast-period check
            scram_trip = True                                                        # trip scram if bad period persisted long enough

        det3 = dial_detent(dial_angles[1])                                           # compute CH3 detent
        ch3_log_max = CH3_LOG_MAX_AT_0 + det3                                        # compute CH3 window top decade
        ch3_log_min = ch3_log_max - CH3_LOG_SPAN_DECADES                             # compute CH3 window bottom decade

        logI3 = math.log10(max(ch3_I_ind, I_FLOOR))                                  # compute log10(CH3 current)
        frac3 = (logI3 - ch3_log_min) / max(1e-9, (ch3_log_max - ch3_log_min))       # map CH3 current into window fraction [0,1]
        frac3 = max(0.0, min(1.0, frac3))                                            # clamp window fraction to [0,1]

        if (not grace) and (ch3_I_ind > CH3_MAX_LOCKOUT_A):                          # check CH3 lockout threshold
            ch3_hi_lockout = True                                                    # latch lockout state
            scram_trip = True                                                        # trip scram on lockout

        if (not grace) and (not moving_inhibit) and ((frac3 <= CH3_LOW_PCT_SCRAM) or (frac3 >= CH3_HI_PCT_SCRAM)):  # window scram check
            scram_trip = True                                                        # trip scram if CH3 leaves allowed window

        if scram_trip:                                                               # if any protection channel requested scram
            scram_active = True                                                      # activate SCRAM state
            scram_start_time = now                                                   # record SCRAM start time
            selected_lever = None                                                    # clear lever selection
            selected_dial = None                                                     # clear dial selection
            lever_active[:] = [False] * NUM_LEVERS                                   # clear lever active highlights
            dial_active[:] = [False] * NUM_DIALS                                     # clear dial active highlights

        rho_prev = rho_new                                                           # store rho for next frame prompt-jump comparison

    else:                                                                            # if not powered or scrammed, relax instruments toward floor
        ch2_I_ind = first_order_lag(ch2_I_ind, I_FLOOR, dt, 0.5)                     # decay CH2 indicated current toward floor
        ch3_I_ind = first_order_lag(ch3_I_ind, I_FLOOR, dt, 0.5)                     # decay CH3 indicated current toward floor
        ch2_period_s = float("inf")                                                  # hide period when not running
        ch2_ln_buf.clear()                                                           # clear period buffer when not running
        ch2_period_bad_time = 0.0                                                    # reset bad-period accumulator

    pygame.draw.rect(screen, GREY, (GRAPH_X, GRAPH_Y, GRAPH_WIDTH, GRAPH_HEIGHT))    # draw graph background rectangle
    linear_width = GRAPH_WIDTH // 2                                                  # compute half width for split plot
    right_start  = GRAPH_X + linear_width                                            # compute x start for right plot

    if len(ch2_history) > 1 and len(ch3_history) > 1:                                # only draw traces if enough points exist
        npts = min(len(ch2_history), len(ch3_history))                               # use common number of points across channels
        ch2_list = list(ch2_history)[-npts:]                                         # slice latest npts CH2 samples
        ch3_list = list(ch3_history)[-npts:]                                         # slice latest npts CH3 samples

        det2 = dial_detent(dial_angles[0])                                           # compute CH2 detent
        fs2 = CH2_RANGES[det2 + 3]                                                   # pick CH2 full-scale from detent

        pts = []                                                                     # create point list for CH2 trace
        for i, I in enumerate(ch2_list):                                             # iterate over CH2 samples with index
            y = GRAPH_Y + (i / max(1, npts - 1)) * GRAPH_HEIGHT                      # map index to y coordinate (time axis)
            frac = max(0.0, min(1.0, I / max(fs2, I_FLOOR)))                         # normalize current to [0,1] of full scale
            x = GRAPH_X + frac * linear_width                                        # map normalized current to x in left plot
            pts.append((x, y))                                                       # append point to polyline list
        pygame.draw.lines(screen, RED, False, smooth_points(pts, steps=6), 2)        # draw smoothed CH2 line trace

        det3 = dial_detent(dial_angles[1])                                           # compute CH3 detent
        ch3_log_max = CH3_LOG_MAX_AT_0 + det3                                        # compute CH3 window top decade
        ch3_log_min = ch3_log_max - CH3_LOG_SPAN_DECADES                             # compute CH3 window bottom decade

        log_pts = []                                                                 # create point list for CH3 trace
        for i, I in enumerate(ch3_list):                                             # iterate over CH3 samples with index
            y = GRAPH_Y + (i / max(1, npts - 1)) * GRAPH_HEIGHT                      # map index to y coordinate (time axis)
            logI = math.log10(max(I, I_FLOOR))                                       # compute log10 current safely
            frac = (logI - ch3_log_min) / max(1e-9, (ch3_log_max - ch3_log_min))     # normalize logI into window [0,1]
            frac = max(0.0, min(1.0, frac))                                          # clamp normalized fraction to [0,1]
            x = right_start + frac * linear_width                                    # map normalized fraction to x in right plot
            log_pts.append((x, y))                                                   # append point to polyline list
        pygame.draw.lines(screen, YELLOW, False, log_pts, 2)                         # draw CH3 line trace (log window)

    pygame.draw.rect(screen, BLACK, (GRAPH_X, GRAPH_Y, linear_width, GRAPH_HEIGHT), 2)          # draw left plot border
    pygame.draw.rect(screen, BLACK, (right_start, GRAPH_Y, linear_width, GRAPH_HEIGHT), 2)     # draw right plot border
    pygame.draw.line(screen, BLACK, (right_start, GRAPH_Y), (right_start, GRAPH_Y + GRAPH_HEIGHT), 2)  # draw split line

    font = pygame.font.SysFont(None, 30)                                             # create base font for main labels
    inst_font = pygame.font.SysFont(None, 20)                                        # create smaller font for instrument readouts
    title_font = pygame.font.SysFont(None, 20)                                       # create small font for plot titles

    det2 = dial_detent(dial_angles[0])                                               # compute CH2 detent for display
    fs2 = CH2_RANGES[det2 + 3]                                                       # compute CH2 full-scale for display
    ch2_info = inst_font.render(f"CH2 (LIN): I={format_amps(ch2_I_ind)}  FS={format_amps(fs2)}", True, BLACK)  # render CH2 info string
    screen.blit(ch2_info, (GRAPH_X, GRAPH_Y - 86))                                   # draw CH2 info above plot

    per_str = "—" if (not power_on) else ("∞" if ch2_period_s == float("inf") else f"{ch2_period_s:.1f}s")      # format period string
    per_info = inst_font.render(f"CH2 Period: {per_str}   (scram @ {CH2_PERIOD_SCRAM_S:.0f}s)", True, BLACK)    # render period info
    screen.blit(per_info, (GRAPH_X, GRAPH_Y - 62))                                   # draw period info above plot

    det3 = dial_detent(dial_angles[1])                                               # compute CH3 detent for display
    ch3_log_max = CH3_LOG_MAX_AT_0 + det3                                            # compute CH3 max decade for display
    ch3_log_min = ch3_log_max - CH3_LOG_SPAN_DECADES                                 # compute CH3 min decade for display
    ch3_info = inst_font.render(                                                     # render CH3 info string surface
        f"CH3 (LOG): I={format_amps(ch3_I_ind)}  window=10^{int(ch3_log_min)}..10^{int(ch3_log_max)} A",         # build CH3 info text
        True,                                                                        # enable antialiasing
        BLACK                                                                        # set text color
    )                                                                                # close render call
    screen.blit(ch3_info, (GRAPH_X, GRAPH_Y - 38))                                   # draw CH3 info above plot

    k_eff = 1.0 / max(1e-9, (1.0 - rho_new))                                         # compute k_eff from rho (guard divide)
    dollars = rho_new / beta                                                         # compute reactivity in dollars ($)

    p_text = font.render(f"Power (display): {power_raw_display:.2f} W", True, BLACK) # render power display text
    screen.blit(p_text, p_text.get_rect(center=(GRAPH_X + GRAPH_WIDTH // 2, GRAPH_Y - 112)))  # draw centered above plot

    k_text = inst_font.render(f"k_eff: {k_eff:.6f}   ρ: {rho_new:+.6f}   $: {dollars:+.2f}", True, BLACK)       # render reactivity readout
    screen.blit(k_text, k_text.get_rect(center=(GRAPH_X + GRAPH_WIDTH // 2, GRAPH_Y - 92)))    # draw centered below power text

    linear_label = title_font.render("Channel 2 (Linear Current)", True, BLACK)      # render left plot title
    screen.blit(linear_label, linear_label.get_rect(center=(GRAPH_X + linear_width // 2, GRAPH_Y - 18)))          # draw left title centered
    log_label = title_font.render("Channel 3 (Log Current)", True, BLACK)            # render right plot title
    screen.blit(log_label, log_label.get_rect(center=(right_start + linear_width // 2, GRAPH_Y - 18)))            # draw right title centered

    y_label = font.render("Time (index)", True, BLACK)                               # render y-axis label text surface
    y_label = pygame.transform.rotate(y_label, 90)                                   # rotate label for vertical display
    screen.blit(y_label, y_label.get_rect(center=(GRAPH_X - 70, GRAPH_Y + GRAPH_HEIGHT // 2)))                    # draw rotated label left

    draw_ticks_and_labels()                                                          # draw axis ticks and numeric labels

    pygame.draw.rect(screen, GREEN if power_on else GREY, power_button_rect)         # draw POWER button with green if on, grey if off
    btn_label = font.render("POWER", True, BLACK)                                    # render POWER button label
    screen.blit(btn_label, btn_label.get_rect(center=power_button_rect.center))      # draw POWER label centered on button

    pygame.draw.rect(screen, SCRAM_RED if scram_active else GREY, scram_button_rect) # draw SCRAM button with red if active, grey otherwise
    scram_text = font.render("SCRAM", True, BLACK)                                   # render SCRAM text label
    screen.blit(scram_text, scram_text.get_rect(center=(scram_button_rect.centerx, scram_button_rect.bottom + 30)))  # draw label under button

    for i in range(NUM_LEVERS):                                                      # draw each lever and its track (only 1)
        x = lever_x_positions[i]                                                     # get lever x position
        y = lever_positions[i]                                                       # get lever y position
        pygame.draw.rect(screen, GREY, (x - 6, LEVER_TRACK_TOP, 12, LEVER_TRACK_BOTTOM - LEVER_TRACK_TOP))         # draw lever track
        handle_color = (                                                             # choose lever handle color by state
            LEVER_INACTIVE_COLOR if (scram_active or not power_on)                   # inactive if scrammed or power off
            else (YELLOW if lever_active[i] else BLUE)                               # yellow if selected, else blue
        )                                                                            # close color selection
        pygame.draw.rect(screen, handle_color, (x - 14, y, 28, LEVER_HEIGHT))        # draw lever handle rectangle
        name = font.render(lever_names[i], True, BLACK)                              # render lever name label
        screen.blit(name, name.get_rect(center=(x, LEVER_TRACK_BOTTOM + 34)))        # draw lever label below track

    scale_x = lever_x_positions[-1] + 95                                             # set x position for reactivity scale
    scale_top = LEVER_TRACK_TOP                                                      # reuse lever top as scale top
    scale_bot = LEVER_TRACK_BOTTOM                                                   # reuse lever bottom as scale bottom
    pygame.draw.line(screen, BLACK, (scale_x, scale_top), (scale_x, scale_bot), 3)   # draw vertical reactivity scale line

    plus_lbl = font.render("+", True, BLACK)                                         # render plus sign label
    minus_lbl = font.render("-", True, BLACK)                                        # render minus sign label
    screen.blit(plus_lbl, plus_lbl.get_rect(center=(scale_x + 26, scale_top - 16)))  # draw plus label near top of scale
    screen.blit(minus_lbl, minus_lbl.get_rect(center=(scale_x + 26, scale_bot + 16)))# draw minus label near bottom of scale

    react_lbl = font.render("Reactivity", True, BLACK)                               # render “Reactivity” label text
    screen.blit(react_lbl, react_lbl.get_rect(midleft=(scale_x + 48, (scale_top + scale_bot) // 2)))               # draw label mid-scale

    rho_span = (0.60 * beta) - (-0.2)                                                # compute total rho span for pointer mapping
    rho_frac = (rho_new - (-0.2)) / max(1e-9, rho_span)                              # map rho into normalized [0,1] fraction
    rho_frac = max(0.0, min(1.0, rho_frac))                                          # clamp normalized fraction
    pointer_y = scale_bot - rho_frac * (scale_bot - scale_top)                       # convert fraction to y coordinate on scale
    pygame.draw.circle(screen, BLACK, (scale_x, int(pointer_y)), 6)                  # draw pointer marker at mapped y position

    for i in range(NUM_DIALS):                                                       # draw each dial control
        cx, cy = dial_centers[i]                                                     # unpack dial center coordinates
        pygame.draw.circle(screen, GREY, (cx, cy), DIAL_RADIUS + 8)                   # draw outer dial bezel ring
        face_color = (                                                               # choose dial face color by state
            DIAL_INACTIVE_COLOR if not power_on                                      # inactive if power is off
            else (YELLOW if dial_active[i] else DIAL_INACTIVE_COLOR)                 # yellow if selected, else inactive color
        )                                                                            # close face color selection
        pygame.draw.circle(screen, face_color, (cx, cy), DIAL_RADIUS)                # draw dial face
        draw_dial_ticks(cx, cy, DIAL_RADIUS)                                         # draw detent tick marks and numbers
        angle_rad = math.radians(dial_angles[i])                                     # convert dial angle to radians for needle
        line_x = cx + DIAL_RADIUS * math.cos(angle_rad)                              # compute needle x endpoint
        line_y = cy + DIAL_RADIUS * math.sin(angle_rad)                              # compute needle y endpoint
        pygame.draw.line(screen, WHITE, (cx, cy), (line_x, line_y), 4)               # draw dial needle line
        cap = font.render(dial_names[i], True, BLACK)                                # render dial name label
        screen.blit(cap, cap.get_rect(center=(cx, cy - DIAL_RADIUS - 52)))           # draw dial label above dial

    pygame.display.flip()                                                            # swap backbuffer to screen (present the frame)
    clock.tick(60)                                                                   # cap loop to ~60 FPS

pygame.quit()                                                                        # cleanly shut down pygame modules
sys.exit()                                                                           # exit the program cleanly
