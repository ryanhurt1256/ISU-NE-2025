def kinetics_rhs(state, rho):                                                         # kinetics derivatives
    n_s, C_s = state                                                                  # unpack state
    dn_dt = ((rho - beta) / Lambda) * n_s + lam * C_s + S_SOURCE                      # dn/dt (1-group PK + source)
    dC_dt = (beta / Lambda) * n_s - lam * C_s                                         # dC/dt (1 delayed group)
    return dn_dt, dC_dt                                                               # return derivatives


def rk4_step(state, dt_sub, rho):                                                     # rk4 integrator step
    n0, C0 = state                                                                    # unpack
    k1n, k1C = kinetics_rhs((n0, C0), rho)                                             # k1
    k2n, k2C = kinetics_rhs((n0 + 0.5 * dt_sub * k1n, C0 + 0.5 * dt_sub * k1C), rho)   # k2
    k3n, k3C = kinetics_rhs((n0 + 0.5 * dt_sub * k2n, C0 + 0.5 * dt_sub * k2C), rho)   # k3
    k4n, k4C = kinetics_rhs((n0 + dt_sub * k3n, C0 + dt_sub * k3C), rho)               # k4
    n_new = n0 + (dt_sub / 6.0) * (k1n + 2 * k2n + 2 * k3n + k4n)                      # new n
    C_new = C0 + (dt_sub / 6.0) * (k1C + 2 * k2C + 2 * k3C + k4C)                      # new C
    return n_new, C_new                                                               # return updated state


SERIAL_PORT, BAUDRATE = "/dev/ttyUSB0", 115200                                        # serial defaults


def setup_serial(port=SERIAL_PORT, baud=BAUDRATE):                                    # open serial if available
    if serial is None:                                                                # if pyserial missing
        return None                                                                   # disable serial
    try:                                                                              # try open serial
        ser = serial.Serial(port, baud, timeout=0.05)                                 # open port
        time.sleep(1.0)                                                               # wait for reset
        return ser                                                                    # return serial object
    except Exception:                                                                 # on failure
        return None                                                                   # return None


ser = setup_serial()                                                                  # initialize serial once


def read_controls_from_serial(ser):                                                   # parse serial line
    if ser is None:                                                                   # if no serial
        return None                                                                   # no data
    try:                                                                              # try read/parse
        raw = ser.readline().decode(errors="ignore").strip()                          # read line
        if not raw:                                                                   # if empty
            return None                                                               # no update
        parts = raw.split(",")                                                        # split csv
        if len(parts) < 6:                                                            # require at least 6 fields
            return None                                                               # invalid
        rods = [float(p) for p in parts[:4]]                                          # parse rods
        power_sw = bool(int(float(parts[4])))                                         # parse power
        scram_sw = bool(int(float(parts[5])))                                         # parse scram
        return rods, power_sw, scram_sw                                               # return values
    except Exception:                                                                 # on any error
        return None                                                                   # ignore


