def first_order_lag(y, x, dt, tau):                                                   # first order lag helper
    if tau <= 1e-6:                                                                   # if tau is essentially zero
        return x                                                                      # return input directly
    alpha = dt / (tau + dt)                                                           # compute alpha
    return y + alpha * (x - y)                                                        # return filtered output


def dial_detent(angle_deg):                                                           # convert dial angle to detent
    d = int(round((angle_deg - (-90.0)) / 30.0))                                      # compute detent from 30° steps
    return max(-3, min(3, d))                                                         # clamp to -3..+3


def angle_from_detent(det):                                                           # convert detent to angle
    return -90.0 + 30.0 * float(det)                                                  # map detent to angle


def format_amps(I):                                                                   # format current to readable units
    I = float(I)                                                                      # ensure float
    a = abs(I)                                                                        # magnitude
    if a >= 1e-6:                                                                     # microamps
        return f"{I/1e-6:.2f} µA"                                                     # return µA
    if a >= 1e-9:                                                                     # nanoamps
        return f"{I/1e-9:.2f} nA"                                                     # return nA
    if a >= 1e-12:                                                                    # picoamps
        return f"{I/1e-12:.2f} pA"                                                    # return pA
    return f"{I:.2e} A"                                                               # return scientific A


def rod_curve(x):                                                                     # rod worth curve fraction
    a = 3.3                                                                           # curve constant
    return 1.0 - math.exp(-a * x)                                                     # return 1-exp(-ax)


def smooth_points(points, steps=6):                                                   # smooth polyline for nicer plots
    smoothed = []                                                                     # output list
    if len(points) < 2:                                                               # if not enough points
        return points                                                                 # return as-is
    for i in range(len(points) - 1):                                                  # loop segments
        x1, y1 = points[i]                                                            # segment start
        x2, y2 = points[i + 1]                                                        # segment end
        for t in range(steps):                                                        # insert intermediate points
            alpha = t / steps                                                         # interpolation fraction
            smoothed.append((x1 * (1 - alpha) + x2 * alpha, y1 * (1 - alpha) + y2 * alpha))  # append interpolated point
    smoothed.append(points[-1])                                                       # include last point
    return smoothed                                                                   # return smoothed list


def draw_dial_ticks(cx, cy, radius):                                                  # draw dial ticks and numbers
