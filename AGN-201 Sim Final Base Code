    angle_step = 30                                                                   # degrees per detent
    for i in range(7):                                                                # loop -3..+3 marks
        angle_deg = -90 - angle_step * (i - 3)                                        # tick angle
        angle_rad = math.radians(angle_deg)                                           # radians
        tick_len = 10 if i == 3 else 6                                                # center tick longer
        label_txt = "0" if i == 3 else str(i - 3)                                     # label text
        outer_x = cx + radius * math.cos(angle_rad)                                   # outer x
        outer_y = cy + radius * math.sin(angle_rad)                                   # outer y
        inner_x = cx + (radius - tick_len) * math.cos(angle_rad)                      # inner x
        inner_y = cy + (radius - tick_len) * math.sin(angle_rad)                      # inner y
        pygame.draw.line(screen, BLACK, (outer_x, outer_y), (inner_x, inner_y), 2)    # draw tick
        label_x = cx + (radius + 22) * math.cos(angle_rad)                            # label x
        label_y = cy + (radius + 22) * math.sin(angle_rad)                            # label y
        label = font.render(label_txt, True, BLACK)                                   # render label
        screen.blit(label, label.get_rect(center=(label_x, label_y)))                 # blit label


