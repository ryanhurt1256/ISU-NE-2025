    det3 = dial_detent(dial_angles[1])                                               # compute CH3 dial detent from its angle
    ch3_log_max = CH3_LOG_MAX_AT_0 + det3                                            # compute CH3 top decade for window
    ch3_log_min = ch3_log_max - CH3_LOG_SPAN_DECADES                                 # compute CH3 bottom decade for window

    for decade in range(int(math.floor(ch3_log_min)),                                # start decade tick at floor(min)
                        int(math.ceil(ch3_log_max)) + 1):                            # end decade tick at ceil(max) inclusive
        frac = (decade - ch3_log_min) / max(1e-9, (ch3_log_max - ch3_log_min))       # compute normalized decade position in window
        frac = max(0.0, min(1.0, frac))                                              # clamp normalized position to [0,1]
        x = right_start + frac * linear_width                                        # compute tick x position in log plot
        y = GRAPH_Y + GRAPH_HEIGHT                                                   # set tick baseline at bottom of graph
        pygame.draw.line(screen, BLACK, (x, y), (x, y + 8), 2)                       # draw tick line
        if frac > 0.03:                                                              # skip label near the split line for readability
            lbl = font.render(f"10^{decade}", True, BLACK)                           # render decade label (10^n)
            screen.blit(lbl, lbl.get_rect(center=(x, y + 22)))                       # draw decade label below tick

    max_time = power_history.maxlen                                                  # use history buffer length as y-axis “time index” span
    for time_tick in range(0, max_time + 1, 50):                                     # draw y ticks every 50 samples
